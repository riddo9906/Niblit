# ---------------------------
# NiblitCore Unified
# ---------------------------
class NiblitCore:
    def __init__(self, memory_path=None):
        log.info("Initializing NiblitCore unified system...")
        self.start_ts = time.time()
        self.db = KnowledgeDB(memory_path) if memory_path else KnowledgeDB()
        self.personality = self.db.get_personality()

        # Modules
        self.llm = safe_call(LLMAdapter, self.db)
        self.analytics = safe_call(AnalyticsModule, self.db)
        self.antifraud = safe_call(AntiFraudModule, self.db)
        self.idea_gen = safe_call(IdeaGenerator, self.db)
        self.reflect = safe_call(ReflectModule, self.db)
        self.self_healer = safe_call(SelfHealer, self.db)
        self.self_teacher = safe_call(SelfTeacher, self.db)
        self.self_maintenance = safe_call(SelfMaintenance, self.db)
        self.cam = safe_call(CounterActiveMembrane, self.db)
        self.self_idea_impl = safe_call(SelfIdeaImplementation, self.db)
        self.slsa_gen = safe_call(SLSAGeneratorModule, self.db)
        self.control_panel = safe_call(ControlPanel, self.db, {})
        self.device_manager = safe_call(DeviceManager)
        self.bios = safe_call(BIOS)
        self.firmware = safe_call(Firmware)
        self.bootloader = safe_call(Bootloader)
        self.fs_manager = safe_call(FileSystemManager)
        self.terminal_tools = safe_call(TerminalTools)
        self.perms = safe_call(PermissionManager)

        self.modules = {
            'analytics': self.analytics, 'antifraud': self.antifraud,
            'ideas': self.idea_gen, 'reflect': self.reflect,
            'llm': self.llm, 'self_healer': self.self_healer,
            'self_teacher': self.self_teacher, 'self_maintenance': self.self_maintenance,
            'cam': self.cam, 'self_idea_impl': self.self_idea_impl,
            'slsa': self.slsa_gen, 'control_panel': self.control_panel,
            'device_manager': self.device_manager, 'bios': self.bios,
            'firmware': self.firmware, 'bootloader': self.bootloader,
            'fs_manager': self.fs_manager, 'terminal_tools': self.terminal_tools,
            'perms': self.perms
        }

        self.self_researcher = safe_call(SelfResearcher, self.db, self.modules)

        # InternetManager
        try:
            self.internet = internet_manager.InternetManager(db=self.db) if internet_manager else None
            if self.internet:
                def quick_summary(query):
                    results = self.internet.search(query, max_results=1)
                    return results[0] if results else "[No info found]"
                self.internet.quick_summary = quick_summary
                log.info("InternetManager loaded successfully.")
        except Exception as e:
            log.warning(f"InternetManager init failed: {e}")
            self.internet = None

        # HFBrain
        self.hf_brain = self._load_hf_brain()
        self.llm_enabled = bool(self.llm and safe_call(self.llm.is_available))
        self.hf_brain_enabled = self.llm_enabled
        if self.hf_brain:
            safe_call(self.hf_brain.enable if self.hf_brain_enabled else self.hf_brain.disable)

        # ---------------------------
        # SLSA Generator
        # ---------------------------
        if SLSAGenerator:
            try:
                self.slsa = SLSAGenerator(interval=20, db_path="niblit.db")
                t = threading.Thread(target=self.slsa.run, daemon=True, name="slsa-generator")
                t.start()
                log.info("[SLSA] Generator integrated and running")
            except Exception as e:
                log.warning(f"[SLSA] Initialization failed: {e}")
                self.slsa = None
        else:
            self.slsa = None

        # Router
        if NiblitRouter:
            self.router = NiblitRouter(self, self.db)
            self.router.start()
        else:
            self.router = None

        self.running = True
        self.persona = {"mode":"hybrid","tone":"balanced","last_user":None}

        self._start_background_threads()
        log.info("NiblitCore unified system initialized.")

    def _load_hf_brain(self):
        try:
            from modules.hf_brain import HFBrain
            brain = HFBrain(db=self.db)
            log.info("HFBrain loaded successfully.")
            return brain
        except Exception as e:
            log.warning(f"HFBrain failed to load: {e}")
            return None

    def _start_background_threads(self):
        threading.Thread(target=self._health_monitor, daemon=True, name="niblit-health").start()

    def _health_monitor(self):
        last_log = 0
        while self.running:
            uptime = int(time.time() - self.start_ts)
            if uptime - last_log >= 120:
                mem_count = len(self.db.recent_interactions(100))
                log.info(f"[HEALTH] uptime={uptime}s memory={mem_count}")
                last_log = uptime
            time.sleep(5)

    # -------------------
    # Core handler
    # -------------------
    def handle(self, text: str) -> str:
        self.persona["last_user"] = text
        intent, meta = parse_intent(text)

        # Memory / Facts
        if intent == "remember":
            self.db.add_fact(meta["key"], meta["value"])
            return f"Saved: {meta['key']}"
        if intent == "time":
            return datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S UTC")
        if intent == "status":
            return f"Memory entries: {len(self.db.recent_interactions(500))}"
        if intent == "learn":
            topic = meta.get("topic","")
            self.db.queue_learning(topic)
            return f"Learning queued → {topic}"
        if intent == "ideas":
            topic = meta.get("topic","")
            return f"Ideas for {topic}: Prototype → Test → Evolve"
        if intent == "shutdown":
            threading.Thread(target=self.shutdown, daemon=True).start()
            return "Shutdown scheduled."
        if intent == "help":
            return self.help_text()

        # LLM toggle
        if intent == "toggle_llm":
            state = meta.get("state","").lower()
            if state in ("on","true","1"):
                self.llm_enabled = True
                if self.hf_brain: safe_call(self.hf_brain.enable)
                self.hf_brain_enabled = True
                return "LLM enabled."
            elif state in ("off","false","0"):
                self.llm_enabled = False
                if self.hf_brain: safe_call(self.hf_brain.disable)
                self.hf_brain_enabled = False
                return "LLM disabled."
            return "Invalid toggle state. Use 'on' or 'off'."

        # Self-research
        if text.lower().startswith("self-research") and self.self_researcher:
            parts = text.split(" ", 2)
            if len(parts) == 2:
                query = parts[1]
                return safe_call(self.self_researcher.handle_command, "web.run", query) or "[Error]"
            elif len(parts) >=3:
                cmd,arg = parts[1],parts[2]
                return safe_call(self.self_researcher.handle_command, cmd,arg) or "[Error]"
            return "[RESEARCH ERROR] Usage: self-research <cmd> <arg> or <query>"

        # InternetManager
        if text.lower().startswith("search ") and self.internet:
            query = text[len("search "):].strip()
            results = self.internet.search(query)
            return "\n".join(results) if results else "[No results found]"
        if text.lower().startswith("summary ") and self.internet:
            query = text[len("summary "):].strip()
            return self.internet.quick_summary(query)

        # ---------------------------
        # SLSA manual trigger
        # ---------------------------
        if intent == "slsa" and self.slsa:
            topic = meta.get("topic")
            if topic:
                safe_call(self.slsa.generate_cycle, topic)
                return f"SLSA generation triggered for topic → {topic}"
            return "Please provide a topic: /slsa <topic>"

        # Router fallback
        if self.router:
            return self.router.process(text)

        # Fallback to HFBrain / LLM / raw chat
        context = "\n".join(r['text'] for r in self.db.recent_interactions(20))
        if self.llm_enabled and self.hf_brain and getattr(self, 'hf_brain_enabled', False):
            resp = safe_call(self.hf_brain.ask_single, text)
            if resp:
                self.db.add_interaction("assistant", resp)
                return resp.strip()
        if self.llm_enabled:
            return safe_call(self.llm.query, text, context=context) or f"I hear you: '{text}'"

        return f"I hear you: '{text}'"

    # -------------------
    # Help / Commands
    # -------------------
    def help_text(self) -> str:
        commands = [
            "help / commands       → show this message",
            "time                  → show current UTC time",
            "status / health       → show memory/health info",
            "shutdown / exit / quit→ shut down the system",
            "remember <key>:<val>  → store a fact",
            "learn about <topic>   → queue learning",
            "ideas about <topic>   → suggest ideas",
            "self-research <cmd>   → run SelfResearcher module",
            "chat <message>        → fallback chat",
            "search <query>        → perform internet search (DuckDuckGo/Wikipedia)",
            "summary <query>       → get quick summary from internet",
            "toggle-llm <on/off>   → enable or disable LLM module",
            "/slsa <topic>         → trigger SLSA generation for topic"
        ]
        return "[NiblitCore Commands]\n" + "\n".join(commands)

    # -------------------
    # Shutdown
    # -------------------
    def shutdown(self):
        log.info("Shutdown initiated…")
        self.running = False
        if self.slsa: self.slsa.stop()
        time.sleep(0.5)
        log.info("Shutdown complete.")

# -------------------
# Self-test
# -------------------
if __name__ == "__main__":
    core = NiblitCore()
    print("[Selftest] NiblitCore running.")
    try:
        while core.running:
            cmd = input("> ").strip()
            print(core.handle(cmd))
    except KeyboardInterrupt:
        core.shutdown()
