import os
import sys
import json
import time
import threading
import logging
from datetime import datetime
from typing import Any, List, Tuple

# ---------------------------
# Logging
# ---------------------------
logging.basicConfig(level=logging.INFO, format='[%(levelname)s] %(message)s')
log = logging.getLogger("NiblitCore")

# ---------------------------
# Utilities
# ---------------------------
def now_iso():
    return datetime.utcnow().isoformat() + "Z"

def timestamp():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def safe_call(fn, *a, **kw):
    try:
        return fn(*a, **kw)
    except Exception as e:
        log.debug("safe_call failure: %s -> %s", fn, e)
        return None

# ---------------------------
# Intent parser
# ---------------------------
def parse_intent(text: str) -> Tuple[str, dict]:
    t = text.strip().lower()
    if t.startswith("remember "):
        payload = t[len("remember "):].strip()
        if ":" in payload:
            k, v = payload.split(":", 1)
            return "remember", {"key": k.strip(), "value": v.strip()}
        return "bad_remember", {}
    if t in ("time", "what time is it", "current time"):
        return "time", {}
    if "weather" in t:
        return "weather", {}
    if t in ("help", "commands"):
        return "help", {}
    if t in ("status", "health"):
        return "status", {}
    if t in ("shutdown", "exit", "quit"):
        return "shutdown", {}
    if t.startswith("learn about "):
        return "learn", {"topic": t[len("learn about "):].strip()}
    if t.startswith("ideas about "):
        return "ideas", {"topic": t[len("ideas about "):].strip()}
    if t.startswith("toggle-llm "):
        state = t[len("toggle-llm "):].strip()
        return "toggle_llm", {"state": state}
    if t.startswith("/slsa "):
        topic = t[len("/slsa "):].strip()
        return "slsa", {"topic": topic}
    return "chat", {}

# ---------------------------
# Knowledge / Memory DB
# ---------------------------
class KnowledgeDB:
    def __init__(self, path='niblit_memory.json'):
        self.path = path
        self.lock = threading.Lock()
        self.data = {
            'facts': [],
            'interactions': [],
            'learning_queue': [],
            'personality': {'mood':'neutral','verbosity':'medium'},
            'meta': {}
        }
        self._load()

    def _load(self):
        try:
            if os.path.exists(self.path):
                with open(self.path,'r',encoding='utf-8') as f:
                    loaded = json.load(f)
                    self.data['facts'] = loaded.get('facts', [])
                    self.data['interactions'] = loaded.get('interactions', [])
                    self.data['learning_queue'] = loaded.get('learning_queue', [])
                    self.data['personality'] = loaded.get('personality', {'mood':'neutral','verbosity':'medium'})
                    self.data['meta'] = loaded.get('meta', {})
        except Exception:
            try: os.rename(self.path, self.path + '.bak')
            except Exception: pass
            self._save()

    def _save(self):
        with self.lock:
            with open(self.path,'w',encoding='utf-8') as f:
                json.dump(self.data,f,indent=2,ensure_ascii=False)

    # Facts
    def add_fact(self, key, value, tags=None):
        tags = tags or []
        self.data['facts'].append({'key': key, 'value': value, 'tags': tags, 'ts': int(time.time())})
        self._save()

    # Interactions
    def add_interaction(self, role, text):
        self.data['interactions'].append({'ts': int(time.time()), 'role': role, 'text': text})
        if len(self.data['interactions']) > 500:
            self.data['interactions'] = self.data['interactions'][-500:]
        self._save()

    def recent_interactions(self, n=20):
        return self.data.get('interactions', [])[-n:]

    # Learning queue
    def queue_learning(self, topic: str):
        self.data['learning_queue'].append({"topic": topic, "status": "queued", "ts": int(time.time())})
        self._save()

    def get_learning_queue(self):
        return self.data.get("learning_queue", [])

    # Personality
    def get_personality(self):
        return self.data.get("personality", {})

# ---------------------------
# Module imports (legacy + fused)
# ---------------------------
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
MODULES_PATH = os.path.join(BASE_DIR, "modules")
if MODULES_PATH not in sys.path:
    sys.path.insert(0, MODULES_PATH)

def safe_import(name, stub_cls=None):
    try:
        mod = __import__(f"modules.{name}", fromlist=[name])
        return getattr(mod, name.capitalize(), None) or mod
    except Exception as e:
        log.warning(f"Module '{name}' failed to load: {e}")
        return stub_cls

class ModuleStub:
    def __init__(self, *a, **kw): pass

# Core modules
SelfResearcher = safe_import("self_researcher", ModuleStub)
LLMAdapter = safe_import("llm_adapter", ModuleStub)
AnalyticsModule = safe_import("analytics", ModuleStub)
AntiFraudModule = safe_import("antifraud", ModuleStub)
IdeaGenerator = safe_import("idea_generator", ModuleStub)
ReflectModule = safe_import("reflect", ModuleStub)
SelfHealer = safe_import("self_healer", ModuleStub)
SelfTeacher = safe_import("self_teacher", ModuleStub)
SelfMaintenance = safe_import("self_maintenance", ModuleStub)
CounterActiveMembrane = safe_import("counter_active_membrane", ModuleStub)
SelfIdeaImplementation = safe_import("self_idea_implementation", ModuleStub)
SLSAGeneratorModule = safe_import("slsa_generator", ModuleStub)
ControlPanel = safe_import("control_panel", ModuleStub)
DeviceManager = safe_import("device_manager", ModuleStub)
BIOS = safe_import("bios", ModuleStub)
Firmware = safe_import("firmware", ModuleStub)
Bootloader = safe_import("bootloader", ModuleStub)
FileSystemManager = safe_import("filesystem_manager", ModuleStub)
TerminalTools = safe_import("terminal_tools", ModuleStub)
PermissionManager = safe_import("permission_manager", ModuleStub)

# InternetManager import
