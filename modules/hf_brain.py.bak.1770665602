#!/usr/bin/env python3
import os
from openai import OpenAI


class HFBrain:
    """
    HuggingFace Router LLM interface for Niblit.
    Uses OpenAI-compatible client with HF router backend.
    """

    def __init__(self):
        token = os.getenv("HF_TOKEN")
        if not token:
            raise RuntimeError("HF_TOKEN not set in environment")

        self.client = OpenAI(
            base_url="https://router.huggingface.co/v1",
            api_key=token,
        )

        # Default model (can be evolved later)
        self.model = "moonshotai/Kimi-K2-Instruct-0905"

    def ask_single(self, prompt: str) -> str:
        try:
            completion = self.client.chat.completions.create(
                model=self.model,
                messages=[
                    {"role": "user", "content": prompt}
                ],
                temperature=0.7,
                max_tokens=300,
            )

            # message is an OBJECT, not a dict
            msg = completion.choices[0].message
            return msg.content.strip() if msg and msg.content else ""

        except Exception as e:
            return f"[HFBrain Error] {e}"


if __name__ == "__main__":
    brain = HFBrain()
    print(brain.ask_single("Say hello in one sentence."))
