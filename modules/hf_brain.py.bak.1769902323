#!/usr/bin/env python3
import os
from openai import OpenAI
from typing import List, Dict

class HFBrain:
    """
    Hugging Face LLM wrapper for Niblit.
    """

    def __init__(self, model_name: str = "moonshotai/Kimi-K2-Instruct-0905"):
        self.model_name = model_name
        hf_token = os.getenv("HF_TOKEN")
        if not hf_token:
            raise RuntimeError("[HFBrain] HF_TOKEN not found in environment variables.")
        
        self.client = OpenAI(
            base_url="https://router.huggingface.co/v1",
            api_key=hf_token,
        )

    def ask(self, messages: List[Dict[str, str]]) -> str:
        try:
            completion = self.client.chat.completions.create(
                model=self.model_name,
                messages=messages,
            )
            return completion.choices[0].message["content"]
        except Exception as e:
            return f"[HFBrain Error] {str(e)}"

    def ask_single(self, prompt: str) -> str:
        return self.ask([{"role": "user", "content": prompt}])
