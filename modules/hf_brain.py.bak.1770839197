#!/usr/bin/env python3
"""
HFBrain — Unified Stateful LLM Brain for Niblit
Integrated with KnowledgeDB / MemoryManager
Author: Riyaad Behardien
"""

import os
import time
from openai import OpenAI


class HFBrain:
    """
    HuggingFace Router LLM interface for Niblit.
    Fully stateful via unified memory DB.
    """

    def __init__(self, db):
        self.db = db  # Unified KnowledgeDB / MemoryManager

        token = os.getenv("HF_TOKEN")
        if not token:
            raise RuntimeError("HF_TOKEN not set in environment")

        self.client = OpenAI(
            base_url="https://router.huggingface.co/v1",
            api_key=token,
        )

        # Model can later be evolved dynamically
        self.model = "moonshotai/Kimi-K2-Instruct-0905"

    # ───────────────────────────────────────────
    # Context assembly
    # ───────────────────────────────────────────
    def _build_context(self, user_prompt: str) -> list:
        messages = []

        # Pull recent interaction memory
        try:
            recent = self.db.recent_interactions(15)
            for entry in recent:
                role = entry.get("role", "user")
                text = entry.get("text", "")
                messages.append({
                    "role": role if role in ("user", "assistant") else "user",
                    "content": text
                })
        except Exception:
            pass

        # Append current user input
        messages.append({
            "role": "user",
            "content": user_prompt
        })

        return messages

    # ───────────────────────────────────────────
    # Single query
    # ───────────────────────────────────────────
    def ask_single(self, prompt: str) -> str:
        try:
            messages = self._build_context(prompt)

            completion = self.client.chat.completions.create(
                model=self.model,
                messages=messages,
                temperature=0.7,
                max_tokens=350,
            )

            msg = completion.choices[0].message
            response = msg.content.strip() if msg and msg.content else ""

            if response:
                # Persist memory
                self.db.add_interaction("user", prompt)
                self.db.add_interaction("assistant", response)
                self.db.add_hf_context(response)

            return response

        except Exception as e:
            return f"[HFBrain Error] {e}"


if __name__ == "__main__":
    print("HFBrain requires unified DB. Do not run standalone.")
if __name__ == "__main__":
    print('Running hf_brain.py')
