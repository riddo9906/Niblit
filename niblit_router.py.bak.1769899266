#!/usr/bin/env python3

class NiblitRouter:
    def __init__(self, brain, memory):
        self.brain = brain
        self.memory = memory

    def start(self):
        pass

    def process(self, user_input):
        cleaned = user_input.strip()

        self.memory.log_event(f"Incoming: {cleaned}")

        # COMMAND MODE
        if cleaned.startswith("/"):
            return self.handle_command(cleaned[1:])

        # NORMAL THINKING
        response = self.brain.think(cleaned)
        print(response)

    def handle_command(self, cmd):
        if cmd == "status":
            print("🧠 Niblit is operational.")
        elif cmd == "memory":
            print(self.memory.get_all())
        elif cmd == "reflect":
            print("🔁 Reflection task queued.")
        else:
            print("❓ Unknown command.")
