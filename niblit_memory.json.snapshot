            "value": "{'language': 'assembly', 'template': 'arm', 'name': 'test_niblit', 'code': '@ test_niblit — Test.\\n@ Target: ARM Linux (GNU assembler)\\n@ Build:  as -o test_niblit.o test_niblit.s && ld test_niblit.o -o test_niblit\\n\\n    .section .data\\nmsg:\\n    .asciz \"test_niblit: Test.\\\\n\"\\nmsg_end:\\n\\n    .section .text\\n    .global _start\\n_start:\\n    @ write(1, msg, len)\\n    mov r0, #1\\n    ldr r1, =msg\\n    ldr r2, =(msg_end - msg)\\n    mov r7, #4\\n    svc #0\\n\\n    @ exit(0)\\n    mov r0, #0\\n    mov r7, #1\\n    svc #0\\n'}",
