            "value": "{'language': 'networking', 'template': 'bash_network', 'name': 'test_niblit', 'code': '#!/usr/bin/env bash\\n# test_niblit — Test.\\nset -euo pipefail\\n\\nHOST=\"${1:-127.0.0.1}\"\\nPORT=\"${2:-9000}\"\\n\\ncheck_port() {\\n    nc -zv \"$HOST\" \"$PORT\" 2>&1 && echo \"Port $PORT is open\" || echo \"Port $PORT is closed\"\\n}\\n\\nscan_host() {\\n    ping -c 3 \"$HOST\"\\n}\\n\\nshow_interfaces() {\\n    ip addr show 2>/dev/null || ifconfig 2>/dev/null || echo \"No network tools found\"\\n}\\n\\nmain() {\\n    echo \"=== Network Utility: test_niblit ===\"\\n    show_interfaces\\n    scan_host\\n    check_port\\n}\\n\\nmain\\n'}",
