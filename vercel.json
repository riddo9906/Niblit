{
  "version": 2,

  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],

  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },

  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],

  "env": {
    "APP_ENV": "production"
  }
}
