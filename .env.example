# Niblit Environment Variables
# Copy this file to .env and fill in the values before running locally.
# On Vercel, set these via the project dashboard under Settings > Environment Variables.
# See VERCEL_SETUP.md for the complete Vercel configuration guide.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  QUICK START                                                            │
# │  1. Copy this file:   cp .env.example .env                             │
# │  2. Fill in at least HF_TOKEN (required) + any optional keys below.    │
# │  3. Run:  python main.py                                                │
# │  Everything else degrades gracefully when a key is absent.             │
# │                                                                         │
# │  VERCEL DEPLOYMENT                                                      │
# │  Go to your Vercel project → Settings → Environment Variables and      │
# │  add each key/value pair below that you want enabled.                  │
# └─────────────────────────────────────────────────────────────────────────┘

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face API token for LLM inference (Phase 4 — primary LLM backend).
# Register at https://huggingface.co/settings/tokens (read scope is sufficient).
# The token must start with "hf_" and is sent as:  Authorization: Bearer hf_xxxxxx
# On Vercel: add HF_TOKEN as a plain environment variable in the Vercel dashboard
# (Settings → Environment Variables → Name: HF_TOKEN, Value: hf_xxxx…).
# All modules check HF_TOKEN → HUGGINGFACE_TOKEN → HF_API_KEY in that order.
HF_TOKEN=your_huggingface_token_here

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4 — LLM PROVIDERS  (optional — at least one recommended)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used by OpenAIAdapter when OPENAI_API_KEY is set.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override the default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic — used by AnthropicAdapter when ANTHROPIC_API_KEY is set.
# Get your key at https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=
# Override the default model (default: claude-3-haiku-20240307)
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4 — RESEARCH APIS  (optional — enhance autonomous research)
# ─────────────────────────────────────────────────────────────────────────────

# SerpEx API key for autonomous internet research.
# Obtain a key at https://serpex.dev — the self-researcher and ALE will use
# it as the primary web search backend (falls back to DuckDuckGo/Wikipedia).
# ALE Step 1 (Research) and Step 27 (SerpexResearch) both use this key.
SERPEX_API_KEY=your_serpex_api_key_here

# GitHub personal access token for GitHub Code Search API.
# Create a fine-grained or classic PAT at https://github.com/settings/tokens
# with the "public_repo" scope (read-only is sufficient).
# Used for code pattern discovery, training dataset retrieval, and automated
# refactoring pattern collection in the autonomous learning pipeline (ALE Step 26).
GITHUB_TOKEN=your_github_token_here

# GitHub Sync — repository where Niblit pushes generated/evolved files.
# GITHUB_REPO is the "owner/repo" slug (e.g. "yourname/Niblit").
# GITHUB_BRANCH is the branch to push to (default: niblit/auto-improve).
# NIBLIT_GITHUB_DRY_RUN=1 (default) means no actual pushes — set to 0 to enable.
GITHUB_REPO=
GITHUB_BRANCH=niblit/auto-improve
NIBLIT_GITHUB_DRY_RUN=1

# Stack Exchange / Stack Overflow API key for bug-solution and code-pattern search.
# Register your app at https://stackapps.com/apps/oauth/register (free).
# Leave blank to use the unauthenticated tier (lower rate limit).
STACKOVERFLOW_API_KEY=

# PyPI API base URL — no key required. Override for internal mirrors only.
PYPI_API_URL=https://pypi.org/pypi

# ── searchcode.com — public code search (no key required) ──────────────────
# searchcode.com indexes open-source code from GitHub, Bitbucket, GitLab,
# Google Code and more.  Niblit uses it as an additional code-pattern research
# backend alongside GitHub Code Search (ALE step 28, SearchcodeDiscovery).
#
# No API key is required.  The defaults below point to the official endpoints.
# Override only if you run a self-hosted searchcode instance.
#
# To add the MCP endpoint to Claude Desktop or VS Code Copilot / Cursor:
#   claude mcp add searchcode --transport http https://api.searchcode.com/v1/mcp
SEARCHCODE_API_URL=https://searchcode.com/api
SEARCHCODE_MCP_URL=https://api.searchcode.com/v1/mcp

# NewsAPI.org key for top-headlines aggregation in the upgrade pipeline.
# Register (free) at https://newsapi.org/register
NEWSAPI_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 3 — KNOWLEDGE / VECTOR DATABASE  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Qdrant vector database for semantic knowledge retrieval.
# A shared VectorStore singleton is wired into the LLM adapter, researcher, and
# knowledge store so every component benefits from semantic search over the KB.
#
# Cloud: https://cloud.qdrant.io  |  Self-host: docker run -p 6333:6333 qdrant/qdrant
# Leave QDRANT_URL blank to use the built-in in-memory fallback (no dependencies).
QDRANT_URL=
QDRANT_API_KEY=
# Collection name (shared across all Niblit components)
QDRANT_COLLECTION=niblit_knowledge

# Sentence-transformer embedding model (local or HF hub repo ID).
# The model is downloaded automatically on first use via sentence-transformers.
# Install:  pip install sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# MCP — MODEL CONTEXT PROTOCOL  (optional — connect AI clients to Niblit)
# ─────────────────────────────────────────────────────────────────────────────

# Enable the MCP server (POST /mcp and GET /mcp/sse endpoints, plus stdio transport).
# MCP lets Claude Desktop, VS Code Copilot, Cursor, and other MCP clients use
# Niblit's tools (chat, search, code generation, memory, autonomous learning…).
# Set to false to disable all MCP endpoints even when the module is imported.
MCP_ENABLED=true

# Bearer token that MCP clients must supply in the Authorization: Bearer <token> header.
# Leave blank to disable authentication on the MCP endpoints (not recommended in production).
MCP_SECRET=

# Host and port for the optional standalone HTTP MCP server
# (python -m modules.mcp_server --http).  Ignored when running inside Flask.
MCP_HOST=0.0.0.0
MCP_PORT=8765

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 5 — SANDBOX EXECUTION  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Enable Docker-based sandbox for safe execution of generated code.
# Requires Docker to be installed: https://docs.docker.com/get-docker/
# Set SANDBOX_ENABLED=true only when Docker is available on the host.
SANDBOX_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_MB=256

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 6 — FULL UPGRADE PIPELINE  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Prometheus metrics server.
# Set PROMETHEUS_ENABLED=true to expose a /metrics endpoint on PROMETHEUS_PORT.
# Requires:  pip install prometheus-client
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL / MISCELLANEOUS
# ─────────────────────────────────────────────────────────────────────────────

# API key to protect /chat and /memory endpoints (leave blank to disable auth).
NIBLIT_API_KEY=

# Flask secret key — change this to a long random string in production.
SECRET_KEY=niblit-secret-change-me

# Comma-separated allowed CORS origins; "*" allows all (default for local dev).
CORS_ORIGINS=*

# Port used when running locally (Vercel ignores this)
PORT=5000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# TRADING BRAIN — Binance API  (optional — enables live market data)
# ─────────────────────────────────────────────────────────────────────────────
# Create keys at https://www.binance.com/en/my/settings/api-management
# Without keys, the Trading Brain runs in read-only/paper mode using public endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Trading pair and interval defaults (override at runtime with 'trading pair <SYMBOL>')
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL=1m
TRADING_KLINE_LIMIT=200
TRADING_CYCLE_SECS=60

# ─────────────────────────────────────────────────────────────────────────────
# LEAN ENGINE — QuantConnect / LEAN CLI  (optional — backtesting & live trading)
# ─────────────────────────────────────────────────────────────────────────────
# Register at https://www.quantconnect.com and create an API token.
# User ID is shown in Account > API at https://www.quantconnect.com/account
LEAN_API_USER_ID=
LEAN_API_TOKEN=
# Local workspace directory for LEAN projects (defaults to ./lean_workspace)
LEAN_WORKSPACE=

# Timeout overrides (seconds)
LEAN_BACKTEST_TIMEOUT_SECS=3600
LEAN_LIVE_TIMEOUT_SECS=86400
LEAN_SWEEP_ITER_TIMEOUT_SECS=900

# ─────────────────────────────────────────────────────────────────────────────
# BACKGROUND TRAINER  (optional — daemon training loop)
# ─────────────────────────────────────────────────────────────────────────────
# Batch size for each training step
TRAINER_BATCH_SIZE=32
# Seconds between training steps (default: 60)
TRAINER_INTERVAL_SECS=60
# Per-step timeout in seconds (default: 30)
TRAINER_STEP_TIMEOUT_SECS=30

# ─────────────────────────────────────────────────────────────────────────────
# NIBLIT RUNTIME FLAGS  (optional — fine-grained feature control)
# ─────────────────────────────────────────────────────────────────────────────
# All default to "true". Set to "false" to disable individual subsystems.
NIBLIT_AUTONOMOUS_ENGINE=true
NIBLIT_IMPROVEMENTS=true
NIBLIT_SELF_IMPROVEMENTS=true
NIBLIT_ORCHESTRATOR=true
NIBLIT_LOOPS=true
NIBLIT_ASYNC=false
NIBLIT_DEBUG=false
NIBLIT_LOG_LEVEL=INFO
# Path where niblit_memory.json and other state files are stored
# Defaults to the project root when blank.
NIBLIT_MEMORY_PATH=

# Set to "1" to enable the pygame game window (requires display; leave "0" on servers)
NIBLIT_GAME_DISPLAY=0
