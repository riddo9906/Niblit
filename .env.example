# Niblit Environment Variables
# Copy this file to .env and fill in the values before running locally.
# On Vercel, set these via the project dashboard under Settings > Environment Variables.
# See VERCEL_SETUP.md for the complete Vercel configuration guide.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  QUICK START                                                            │
# │  1. Copy this file:   cp .env.example .env                             │
# │  2. Fill in at least HF_TOKEN (required) + any optional keys below.    │
# │  3. Run:  python main.py                                                │
# │  Everything else degrades gracefully when a key is absent.             │
# │                                                                         │
# │  VERCEL DEPLOYMENT                                                      │
# │  Go to your Vercel project → Settings → Environment Variables and      │
# │  add each key/value pair below that you want enabled.                  │
# └─────────────────────────────────────────────────────────────────────────┘

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face API token for LLM inference (Phase 4 — primary LLM backend).
# Register at https://huggingface.co/settings/tokens (read scope is sufficient).
# The token must start with "hf_" and is sent as:  Authorization: Bearer hf_xxxxxx
# On Vercel: add HF_TOKEN as a plain environment variable in the Vercel dashboard
# (Settings → Environment Variables → Name: HF_TOKEN, Value: hf_xxxx…).
# All modules check HF_TOKEN → HUGGINGFACE_TOKEN → HF_API_KEY in that order.
HF_TOKEN=your_huggingface_token_here

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4 — LLM PROVIDERS  (optional — at least one recommended)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used by OpenAIAdapter when OPENAI_API_KEY is set.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override the default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic — used by AnthropicAdapter when ANTHROPIC_API_KEY is set.
# Get your key at https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=
# Override the default model (default: claude-3-haiku-20240307)
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Active LLM provider: "qwen" (local default), "hf", or "anthropic".
# Local Qwen is primary by default; HuggingFace and Anthropic are selectable.
# Switch at runtime with the CLI command: llm-provider hf|anthropic|qwen|status
NIBLIT_LLM_PROVIDER=qwen

# Brain routing mode — controls which intelligence source handles each prompt.
#   balanced  (default) — smart routing: simple prompts → local brain;
#                         knowledge-heavy prompts → local brain + Niblit KB context;
#                         complex prompts → cloud LLM (falls back to local brain).
#   local     — all prompts handled by local brain (offline-friendly).
#   offline   — no cloud calls; local brain + Niblit KB context only.
#   power     — hybrid: local draft → cloud refinement (highest quality).
#
# In all modes the local brain responds as Niblit.
NIBLIT_BRAIN_MODE=balanced

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4 — RESEARCH APIS  (optional — enhance autonomous research)
# ─────────────────────────────────────────────────────────────────────────────

# SerpEx API key for autonomous internet research.
# Obtain a key at https://serpex.dev — the self-researcher and ALE will use
# it as the primary web search backend (falls back to DuckDuckGo/Wikipedia).
# ALE Step 1 (Research) and Step 27 (SerpexResearch) both use this key.
SERPEX_API_KEY=your_serpex_api_key_here

# SerpAPI key for Google/Bing/Yahoo search results.
# Register at https://serpapi.com — free tier: 100 searches/month.
# InternetManager uses this as the secondary search backend (after SerpEx,
# before DuckDuckGo). Requires: pip install google-search-results
SERPAPI_API_KEY=your_serpapi_api_key_here

# GitHub personal access token for GitHub Code Search API.
# Create a fine-grained or classic PAT at https://github.com/settings/tokens
# with the "public_repo" scope (read-only is sufficient).
# Used for code pattern discovery, training dataset retrieval, and automated
# refactoring pattern collection in the autonomous learning pipeline (ALE Step 26).
GITHUB_TOKEN=your_github_token_here

# GitHub Sync — repository where Niblit pushes generated/evolved files.
# GITHUB_REPO is the "owner/repo" slug (e.g. "yourname/Niblit").
# GITHUB_BRANCH is the branch to push to (default: niblit/auto-improve).
# NIBLIT_GITHUB_DRY_RUN=1 (default) means no actual pushes — set to 0 to enable.
GITHUB_REPO=
GITHUB_BRANCH=niblit/auto-improve
NIBLIT_GITHUB_DRY_RUN=1

# Stack Exchange / Stack Overflow API key for bug-solution and code-pattern search.
# Register your app at https://stackapps.com/apps/oauth/register (free).
# Leave blank to use the unauthenticated tier (lower rate limit).
STACKOVERFLOW_API_KEY=

# PyPI API base URL — no key required. Override for internal mirrors only.
PYPI_API_URL=https://pypi.org/pypi

# ── searchcode.com — public code search (no key required) ──────────────────
# searchcode.com indexes open-source code from GitHub, Bitbucket, GitLab,
# Google Code and more.  Niblit uses it as an additional code-pattern research
# backend alongside GitHub Code Search (ALE step 28, SearchcodeDiscovery).
#
# No API key is required.  The defaults below point to the official endpoints.
# Override only if you run a self-hosted searchcode instance.
#
# To add the MCP endpoint to Claude Desktop or VS Code Copilot / Cursor:
#   claude mcp add searchcode --transport http https://api.searchcode.com/v1/mcp
SEARCHCODE_API_URL=https://searchcode.com/api
SEARCHCODE_MCP_URL=https://api.searchcode.com/v1/mcp

# NewsAPI.org key for top-headlines aggregation in the upgrade pipeline.
# Register (free) at https://newsapi.org/register
NEWSAPI_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 3 — KNOWLEDGE / VECTOR DATABASE  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Qdrant vector database for semantic knowledge retrieval.
# A shared VectorStore singleton is wired into the LLM adapter, researcher, and
# knowledge store so every component benefits from semantic search over the KB.
#
# Cloud: https://cloud.qdrant.io  |  Self-host: docker run -p 6333:6333 qdrant/qdrant
# Leave QDRANT_URL blank to use the built-in in-memory fallback (no dependencies).
QDRANT_URL=
QDRANT_API_KEY=
# Collection name (shared across all Niblit components)
QDRANT_COLLECTION=niblit_knowledge
# Prefix prepended to every collection name used by HybridQdrantManager (default: niblit)
QDRANT_COLLECTION_PREFIX=niblit

# Sentence-transformer embedding model (local or HF hub repo ID).
# The model is downloaded automatically on first use via sentence-transformers.
# Install:  pip install sentence-transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ─────────────────────────────────────────────────────────────────────────────
# MCP — MODEL CONTEXT PROTOCOL  (optional — connect AI clients to Niblit)
# ─────────────────────────────────────────────────────────────────────────────

# Enable the MCP server (POST /mcp and GET /mcp/sse endpoints, plus stdio transport).
# MCP lets Claude Desktop, VS Code Copilot, Cursor, and other MCP clients use
# Niblit's tools (chat, search, code generation, memory, autonomous learning…).
# Set to false to disable all MCP endpoints even when the module is imported.
MCP_ENABLED=true

# Bearer token that MCP clients must supply in the Authorization: Bearer <token> header.
# Leave blank to disable authentication on the MCP endpoints (not recommended in production).
MCP_SECRET=

# Host and port for the optional standalone HTTP MCP server
# (python -m modules.mcp_server --http).  Ignored when running inside Flask.
MCP_HOST=0.0.0.0
MCP_PORT=8765

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 5 — SANDBOX EXECUTION  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Enable Docker-based sandbox for safe execution of generated code.
# Requires Docker to be installed: https://docs.docker.com/get-docker/
# Set SANDBOX_ENABLED=true only when Docker is available on the host.
SANDBOX_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_MB=256

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 6 — FULL UPGRADE PIPELINE  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Prometheus metrics server.
# Set PROMETHEUS_ENABLED=true to expose a /metrics endpoint on PROMETHEUS_PORT.
# Requires:  pip install prometheus-client
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL / MISCELLANEOUS
# ─────────────────────────────────────────────────────────────────────────────

# API key to protect /chat and /memory endpoints (leave blank to disable auth).
NIBLIT_API_KEY=

# Flask secret key — change this to a long random string in production.
SECRET_KEY=niblit-secret-change-me

# Comma-separated allowed CORS origins; "*" allows all (default for local dev).
CORS_ORIGINS=*

# Port used when running locally (Vercel ignores this)
PORT=5000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# TRADING BRAIN — Binance API  (optional — enables live market data)
# ─────────────────────────────────────────────────────────────────────────────
# Create keys at https://www.binance.com/en/my/settings/api-management
# Without keys, the Trading Brain runs in read-only/paper mode using public endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Trading pair and interval defaults (override at runtime with 'trading pair <SYMBOL>')
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL=1m
TRADING_KLINE_LIMIT=200
TRADING_CYCLE_SECS=60

# ─────────────────────────────────────────────────────────────────────────────
# MARKET DATA PROVIDERS  (optional — used by MarketDataProviders module)
# ─────────────────────────────────────────────────────────────────────────────

# Twelve Data — real-time & historical stock/forex/crypto data.
# Get a free key at https://twelvedata.com/apikey
TWELVE_DATA_API_KEY=

# OANDA — forex & CFD broker REST API.
# ⚠️  OANDA does NOT accept registrations from South Africa (and several other
#     restricted regions).  If you are in South Africa, use CCXT instead — see
#     the CCXT block below for SA-friendly exchanges (Binance, Bybit, Kraken, OKX).
# Create a practice or live account at https://www.oanda.com/
# OANDA_ENVIRONMENT: "practice" (fxTrade Practice) or "live" (fxTrade)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# CCXT — 100+ crypto exchanges; SA-friendly alternative to OANDA for forex/CFD data.
# No API key required for public market data (prices, OHLCV, order books).
# For authenticated trading set CCXT_EXCHANGE_API_KEY / CCXT_EXCHANGE_API_SECRET.
# Set CCXT_EXCHANGE to any CCXT exchange id, e.g. binance, bybit, kraken, okx.
# SA-accessible exchanges: binance, bybit, kraken, okx, kucoin, gate
# Install: pip install ccxt
CCXT_EXCHANGE=binance
CCXT_EXCHANGE_API_KEY=
CCXT_EXCHANGE_API_SECRET=

# Alpaca — commission-free stock & crypto brokerage.
# Generate paper/live keys at https://app.alpaca.markets/paper/dashboard/overview
# Set ALPACA_PAPER=false to use the live endpoint.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# ─────────────────────────────────────────────────────────────────────────────
# LEAN ENGINE — QuantConnect / LEAN CLI  (optional — backtesting & live trading)
# ─────────────────────────────────────────────────────────────────────────────
# Register at https://www.quantconnect.com and create an API token.
# User ID is shown in Account > API at https://www.quantconnect.com/account
# LEAN_API_USER_ID / LEAN_API_TOKEN are the primary keys for the LEAN CLI wrapper.
# QC_USER_ID / QC_API_CRED are used by LeanDeployEngine (REST API v2).
# Note: if you previously set QC_API_TOKEN, rename it to QC_API_CRED.
LEAN_API_USER_ID=
LEAN_API_TOKEN=
QC_USER_ID=
QC_API_CRED=
# Local workspace directory for LEAN projects (defaults to ./lean_workspace)
LEAN_WORKSPACE=

# Timeout overrides (seconds)
LEAN_BACKTEST_TIMEOUT_SECS=3600
LEAN_LIVE_TIMEOUT_SECS=86400
LEAN_SWEEP_ITER_TIMEOUT_SECS=900

# ─────────────────────────────────────────────────────────────────────────────
# BACKGROUND TRAINER  (optional — daemon training loop)
# ─────────────────────────────────────────────────────────────────────────────
# Batch size for each training step
TRAINER_BATCH_SIZE=32
# Seconds between training steps (default: 60)
TRAINER_INTERVAL_SECS=60
# Per-step timeout in seconds (default: 30)
TRAINER_STEP_TIMEOUT_SECS=30
# Backoff in seconds after a failed training step (default: 30)
TRAINER_BACKOFF_SECS=30

# ─────────────────────────────────────────────────────────────────────────────
# SCRAPY RESEARCH ENGINE  (optional — web scraping research backend)
# ─────────────────────────────────────────────────────────────────────────────
# Maximum results returned per search query (default: 10)
SCRAPY_MAX_RESULTS=10
# Per-search HTTP timeout in seconds (default: 20)
SCRAPY_TIMEOUT=20

# ─────────────────────────────────────────────────────────────────────────────
# RESEARCH APIS — additional endpoints  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Wikipedia REST API base URL — no key required.
# Override only if you proxy/mirror Wikipedia content internally.
WIKI_API_URL=https://en.wikipedia.org/api/rest_v1/page/summary/{}

# ─────────────────────────────────────────────────────────────────────────────
# NIBLIT RUNTIME FLAGS  (optional — fine-grained feature control)
# ─────────────────────────────────────────────────────────────────────────────
# All default to "true". Set to "false" to disable individual subsystems.
NIBLIT_AUTONOMOUS_ENGINE=true
NIBLIT_IMPROVEMENTS=true
NIBLIT_SELF_IMPROVEMENTS=true
NIBLIT_ORCHESTRATOR=true
NIBLIT_LOOPS=true
NIBLIT_ASYNC=false
NIBLIT_DEBUG=false
NIBLIT_LOG_LEVEL=INFO
# Path where niblit_memory.json and other state files are stored
# Defaults to the project root when blank.
NIBLIT_MEMORY_PATH=

# Set to "1" to enable the pygame game window (requires display; leave "0" on servers)
NIBLIT_GAME_DISPLAY=0

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY MEMBRANE  (optional — rate-limiting and anomaly detection)
# ─────────────────────────────────────────────────────────────────────────────
# Rolling window size in seconds for rate-limiting (default: 60)
NIBLIT_RATE_WINDOW=60
# Maximum requests allowed within the window (default: 60)
NIBLIT_RATE_LIMIT=60
# Duration in seconds to block an IP after exceeding the rate limit (default: 300)
NIBLIT_BLOCK_SECS=300
# Maximum payload size in bytes accepted by /chat (default: 262144 = 256 KB)
NIBLIT_MAX_PAYLOAD=262144
# Multiplier above the rolling average that triggers an anomaly alert (default: 3.0)
NIBLIT_SPIKE_RATIO=3.0
# Maximum consecutive auth failures before blocking a client (default: 10)
NIBLIT_MAX_FAIL_STREAK=10
# Maximum number of security events kept in the in-memory log (default: 1000)
NIBLIT_LOG_MAX_EVENTS=1000

# ─────────────────────────────────────────────────────────────────────────────
# MODULE INTERVALS  (optional — tune background loop frequencies)
# ─────────────────────────────────────────────────────────────────────────────
# DeploymentBridge state-save interval in seconds (default: 120)
NIBLIT_BRIDGE_INTERVAL=120

# ModuleAutonomy health-check / self-improve / unify intervals in seconds
NIBLIT_AUTONOMY_HEALTH_INTERVAL=60
NIBLIT_AUTONOMY_IMPROVE_INTERVAL=300
NIBLIT_AUTONOMY_UNIFY_INTERVAL=600

# NiblitRuntime self-improvement loop (default: 3600 = 1 hour)
NIBLIT_RT_IMPROVE_INTERVAL=3600
# Starting runtime level (default: 1.0)
NIBLIT_RT_INITIAL_LEVEL=1.0
# Level increment per improvement cycle (default: 0.1)
NIBLIT_RT_INCREMENT=0.1
# Path for persisting the runtime level between restarts (default: niblit_runtime_level.json)
NIBLIT_RUNTIME_STATE=

# AutonomousNetwork peer-evolution / health / failure-threshold settings
NIBLIT_NET_EVOLVE_INTERVAL=300
NIBLIT_NET_HEALTH_INTERVAL=60
NIBLIT_NET_MAX_FAILURES=5

# ─────────────────────────────────────────────────────────────────────────────
# DEVICE / PLATFORM FLAGS  (optional — OS and hardware integration)
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" or "true" to enable Raspberry-Pi / embedded car-mode startup
NIBLIT_CAR_MODE=0
# Set to "1" to force console-only mode (no GUI widgets)
NIBLIT_CONSOLE_MODE=0
# Set to "1" to enable DeviceMesh peer-spreading across the local network
NIBLIT_MESH_SPREAD=0
# Set to "1" to enable automatic GitHub deep-research background scans
NIBLIT_GH_DEEP_AUTOSCAN=0

# Comma-separated list of extra shell commands the DeviceControl module may run.
# Leave blank to use the built-in safe allowlist.
NIBLIT_CMD_ALLOWLIST=
# Set to "1" to disable the DeviceControl allowlist (⚠️  not recommended in production)
NIBLIT_CMD_UNRESTRICTED=0

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL / PATH OVERRIDES  (optional — custom storage locations)
# ─────────────────────────────────────────────────────────────────────────────

# ── Local brain inference (QwenLocalBrain / GGUF) ────────────────────────────
# Point to your pre-built GGUF file (~390 MB, no PyTorch required).
# Build the model with:
#   mkdir -p ~/models
#   wget -O ~/models/qwen2.5-0.5b-instruct-q4_k_m.gguf \
#     https://huggingface.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF/resolve/main/qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_GGUF_MODEL_PATH=~/models/qwen2.5-0.5b-instruct-q4_k_m.gguf

# Inference backend:
#   http       — recommended (default). llama-server loads the model once and
#                keeps it in RAM; each Niblit call is a lightweight HTTP
#                request (no model reload per call).
#                Start llama-server first in a separate Termux session:
#                  ~/llama.cpp/build/bin/llama-server \
#                      -m ~/models/qwen2.5-0.5b-instruct-q4_k_m.gguf \
#                      --port 8080 --host 127.0.0.1 -c 2048 -t 4
#   subprocess — CPU/RAM heavy: reloads the full model from disk on every
#                call. Niblit now forces non-interactive llama-cli mode to
#                avoid terminal takeover, but HTTP is still the preferred
#                setup for persistent model sessions.
#   python     — llama-cpp-python (desktop/server only, requires compilation).
#   auto       — probes http → subprocess → python in order.
NIBLIT_GGUF_BACKEND=http

# Path to the pre-built llama.cpp CLI binary (subprocess backend).
# Build on Termux with:
#   pkg install git cmake clang make
#   git clone https://github.com/ggerganov/llama.cpp ~/llama.cpp
#   cd ~/llama.cpp && mkdir -p build && cd build
#   cmake .. -DLLAMA_NATIVE=OFF -DLLAMA_BUILD_TESTS=OFF
#   cmake --build . -j1
# When Niblit runs inside proot, use the absolute Termux path:
#   NIBLIT_LLAMA_BINARY=/data/data/com.termux/files/home/llama.cpp/build/bin/llama-cli
NIBLIT_LLAMA_BINARY=~/llama.cpp/build/bin/llama-cli

# HTTP bridge for the two-session Termux/proot setup (http backend).
# Leave blank to use the default (http://127.0.0.1:8080).
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
NIBLIT_LLAMA_SERVER_TIMEOUT=120

# Context window size and CPU threads for local inference.
# Reduce n_ctx on low-RAM devices (e.g. 512 for < 2 GB RAM).
NIBLIT_GGUF_N_CTX=2048
NIBLIT_GGUF_N_THREADS=

# ── Fine-tuning pipeline (LLMArchitectEngine — separate from inference) ───────
# Path to a local GGUF/ONNX model file for the local LLM adapter.
LOCAL_MODEL_PATH=
# SQLite database for the local LLM adapter (defaults to writable temp dir)
LOCAL_LLM_DB_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# LLM TRAINING PIPELINE  (ALE Step 32 — LLMArchitectEngine)
# ─────────────────────────────────────────────────────────────────────────────
# These variables activate the four-stage LLM engineering pipeline that runs
# autonomously every 10 ALE cycles: data curation → SFT → DPO → evaluation.
#
# GETTING STARTED:
#   1. Set LOCAL_MODEL_PATH to any HuggingFace causal-LM (small = faster).
#      Recommended free starters (safetensors, for fine-tuning — NOT inference):
#        Qwen/Qwen2.5-0.5B-Instruct    (0.5B — runs on CPU, ~1 GB RAM)
#        microsoft/phi-2               (2.7B — good on 8 GB RAM)
#        mistralai/Mistral-7B-v0.3     (7B — needs GPU / 16 GB RAM)
#   2. Uncomment the trl/peft block in requirements.txt and install.
#   3. Restart Niblit.  Step 32 will activate automatically.
#
#   ⚠️  LOCAL_MODEL_PATH is for LoRA/QLoRA fine-tuning only.
#   For local inference, use NIBLIT_GGUF_MODEL_PATH above.

# ── Local model for fine-tuning ───────────────────────────────────────────────
# Set to a HuggingFace model ID or a local path containing model files.
# Example: LOCAL_MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
# Leave blank to use BrainTrainer-only mode (no GPU required).

# ── LoRA hyperparameters ──────────────────────────────────────────────────────
# These match the recommended defaults from the LoRA paper and axolotl configs.
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05

# ── SFT (Supervised Fine-Tuning) hyperparameters ─────────────────────────────
SFT_EPOCHS=1
SFT_BATCH_SIZE=2
SFT_LR=2e-4

# ── DPO (Direct Preference Optimisation) hyperparameters ────────────────────
DPO_LR=1e-5
DPO_BETA=0.1

# ── Output paths for fine-tuned checkpoints ──────────────────────────────────
# Directory where LoRA SFT and DPO checkpoints are saved.
NIBLIT_FINETUNE_OUTPUT_DIR=
# Path to the SFT training dataset JSONL (prompt, completion pairs).
NIBLIT_SFT_DATASET_PATH=
# Path to the DPO preference dataset JSONL (prompt, chosen, rejected).
NIBLIT_DPO_DATASET_PATH=
# Path to the evaluation log JSONL (hit-rate + reward scores per run).
NIBLIT_EVAL_LOG_PATH=

# ── Experiment tracking ────────────────────────────────────────────────────────
# WandB — track training runs, eval metrics, and hyperparameters.
# Sign up free at https://wandb.ai  →  wandb login  →  copy API key.
WANDB_API_KEY=
WANDB_PROJECT=niblit-llm

# MLflow — alternative open-source experiment tracker (self-hosted or Databricks).
# MLFLOW_TRACKING_URI=http://localhost:5001

# ── Tokenizer training ────────────────────────────────────────────────────────
# Path to store a domain-specific BPE tokenizer trained on Niblit's KB text.
# Set to a directory path; Niblit will write sentencepiece model files there.
# Requires: pip install sentencepiece
NIBLIT_TOKENIZER_DIR=

# ── LLM evaluation harness ───────────────────────────────────────────────────
# Run lm-eval-harness benchmarks (MMLU, HellaSwag, GSM8K) after each SFT pass.
# Requires: pip install lm-eval
# Comma-separated task names: mmlu,hellaswag,gsm8k
NIBLIT_EVAL_TASKS=mmlu

# ─────────────────────────────────────────────────────────────────────────────
# ALTERNATIVE / SECONDARY LLM PROVIDERS
# ─────────────────────────────────────────────────────────────────────────────
# These providers are used by LLMTrainingAgent and LLMArchitectEngine as
# higher-quality sources for generating training pairs and synthetic data.

# Together AI — runs open-source models (Llama, Mistral, Qwen, etc.)
# Free $25 credit on signup: https://api.together.xyz
# Docs: https://docs.together.ai/reference/completions
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Groq — ultra-fast inference (Llama, Mixtral, Gemma)
# Free tier: 30 req/min  https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fireworks AI — fast and cheap open-source inference
# Free $1 credit on signup: https://fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Cohere — generate + embed + rerank
# Free trial: https://cohere.com/pricing
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_GENERATE_MODEL=command-r-plus

# ─────────────────────────────────────────────────────────────────────────────
# TRADING AI — ENHANCED CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# ── Temporal Fusion Transformer market model ─────────────────────────────────
# When set, TradingBrain uses a TFT forecast as a second-opinion signal.
# Requires: pip install pytorch-forecasting pytorch-lightning
# Set TRADING_TFT_ENABLED=1 to activate once pytorch-forecasting is installed.
TRADING_TFT_ENABLED=0
# Path to a pre-trained TFT checkpoint (leave blank to train from scratch).
TRADING_TFT_CHECKPOINT=
# Forecast horizon in candles (how many steps ahead TFT predicts).
TRADING_TFT_HORIZON=10

# ── Portfolio optimisation & risk management ─────────────────────────────────
# Requires: pip install PyPortfolioOpt quantstats
TRADING_KELLY_ENABLED=0
# Fraction of Kelly (0.25 = quarter-Kelly, safer for live trading)
TRADING_KELLY_FRACTION=0.25
# Maximum drawdown percentage before the circuit breaker pauses trading
TRADING_MAX_DRAWDOWN_PCT=15.0

# ── RL trading policy additional hyperparameters ─────────────────────────────
# These supplement modules/rl_trading_policy.py (PPO, DQN, Transformer)
NIBLIT_RL_ENABLED=0
# Learning rate for PPO/DQN updates
TRADING_RL_LR=3e-4
# Discount factor for reward shaping
TRADING_RL_GAMMA=0.99
# Number of environment steps between policy updates (PPO)
TRADING_RL_UPDATE_STEPS=128
# SQLite database for the AI Dev Lab experiment registry
AI_DEV_LAB_DB_PATH=
# SQLite path for the fused memory / knowledge store
FUSED_MEMORY_DB_PATH=
# JSON path for ALE checkpoint state (defaults to ale_state.json)
ALE_CHECKPOINT_PATH=
# Directory where the evolution engine writes evolved module files
EVOLVED_DIR=
# Primary niblit memory database path
NIBLIT_DB_PATH=
# SQLite path for the structured knowledge store (niblit_data.sqlite)
NIBLIT_SQLITE_DB_PATH=
# SQLite path for the multi-level cache
NIBLIT_CACHE_DB_PATH=
# Directory for niblit_data and persistent module state (device mesh, github deep-research)
NIBLIT_DATA_DIR=
# Paths for game-engine log and state files
NIBLIT_GAME_LOG_PATH=
NIBLIT_GAME_STATE_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# MOBILE / KIVY CLIENT  (optional — Kivy Android/iOS app)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL that the Kivy app connects to (default: http://10.0.2.2:5000)
NIBLIT_API_URL=http://10.0.2.2:5000

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS  (optional — enable/disable optional UI and API endpoints)
# ─────────────────────────────────────────────────────────────────────────────
MOBILE_ENABLED=true
ENABLE_DASHBOARD=true
ENABLE_MEMORY_API=true

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION BEHAVIOUR  (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Set APP_DEBUG=1 to enable uvicorn auto-reload (development only)
APP_DEBUG=0
# Log format: "json" or "text" (default: json)
LOG_FORMAT=json


# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPER TOOLING  (optional — local development only)
# ─────────────────────────────────────────────────────────────────────────────

# Python log level for Niblit modules.
# Set to DEBUG to see routing/classification metadata and import traces.
# Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL (default: WARNING)
NIBLIT_LOG_LEVEL=WARNING

# Pre-commit: skip specific hooks by listing their IDs (comma-separated).
# Example: SKIP=ruff,black  make pre-commit
# Leave empty to run all hooks.
# See: https://pre-commit.com/#temporarily-disabling-hooks
SKIP=

# Ruff / Black / Mypy: override project-level settings if needed.
# These are read by the respective tools when invoked from the CLI.
# Normally configured via pyproject.toml — only set here for CI overrides.
RUFF_CONFIG=pyproject.toml
BLACK_CONFIG=pyproject.toml
MYPY_CONFIG_FILE=pyproject.toml

# Pytest: extra CLI flags appended to every test run.
# Example: PYTEST_ADDOPTS="-v --tb=long"
PYTEST_ADDOPTS=

# Coverage: minimum required coverage percentage for CI gates.
# Used by `make test-coverage` and the coverage section in pyproject.toml.
COVERAGE_MIN_PERCENT=10
