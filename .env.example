# Niblit Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# --- Hugging Face API (required for AI features) ---
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_api_token_here

# --- Flask Configuration ---
FLASK_ENV=production
# Set a strong random secret key (e.g., run: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_a_random_secret_key

# --- Niblit Identity (optional) ---
# Override the default AI personality name
NIBLIT_NAME=Niblit
NIBLIT_MOOD=neutral
