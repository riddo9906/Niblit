import os

def get_all_py_files(base_dir):
    """Return a list of all Python files in a directory recursively."""
    py_files = []
    for root, dirs, files in os.walk(base_dir):
        for f in files:
            if f.endswith(".py"):
                py_files.append(os.path.join(root, f))
    return py_files

def check_circular_imports():
    """Placeholder: implement advanced circular import detection if needed"""
    # For now, we just return an empty list
    return []

def check_missing_modules(imported_modules, available_modules):
    """Check for modules that are imported but not available"""
    missing = [m for m in imported_modules if m not in available_modules]
    return missing
