# tools/runtime_profiles/wsl-ubuntu.env
# ─────────────────────────────────────────────────────────────────────────────
# Runtime profile: wsl-ubuntu
# Use for Ubuntu on Windows Subsystem for Linux (WSL) desktop deployments.
# Target hardware: ~20 GB RAM, i7-7700 (4 cores / 8 threads)
# Model: Llama 3.2 1B Q4 GGUF — stable 16K context runtime
# ─────────────────────────────────────────────────────────────────────────────

# Application identity
NIBLIT_APP_NAME=niblit
NIBLIT_RUNTIME_PROFILE=wsl-ubuntu

# Socket / transport
NIBLIT_CTL_SOCKET=/tmp/niblit-ctl.sock
NIBLIT_CTL_HOST=
NIBLIT_CTL_PORT=

# Inference backend
NIBLIT_GGUF_BACKEND=http
NIBLIT_LLAMA_PORT=8080
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
# 16K context window — Llama 3.2 1B supports 128K natively; 16K is stable on
# ~20 GB RAM with i7-7700 without saturating the KV cache or CPU bandwidth.
NIBLIT_GGUF_N_CTX=16384
# Use 4 physical threads — leaves headroom for OS + Niblit Python runtime.
NIBLIT_GGUF_N_THREADS=4
# Max tokens generated per response — 512 gives richer output within budget.
NIBLIT_LOCAL_MAX_NEW=512

# Model paths — Ubuntu/WSL desktop defaults
NIBLIT_GGUF_MODEL_PATH=/home/riddo9906/models/Llama-3.2-1B-Instruct-Q4_K_M.gguf
NIBLIT_MODEL_QWEN=/home/riddo9906/models/qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_MODEL_LLAMA3=/home/riddo9906/models/Llama-3.2-1B-Instruct-Q4_K_M.gguf
NIBLIT_LLAMA_BINARY=/home/riddo9906/llama.cpp/build/bin/llama-server

# 16K context cognitive budget
# KB context injected per inference call (~1500 tokens at 4 chars/token)
NIBLIT_BRAIN_CONTEXT_MAX_CHARS=6000
# Max chars per KB snippet
NIBLIT_KB_TEXT_MAX_CHARS=1500
# Chat history turns injected into brain think() — deeper reflection horizon
NIBLIT_BRAIN_CHAT_HISTORY_LIMIT=20
# Max chars per injected history message — allows richer message content
NIBLIT_BRAIN_CHAT_HISTORY_CONTENT_CHARS=800
# Chat-completions conversation depth
NIBLIT_CHAT_MAX_HISTORY=40
# Chat-completions knowledge context budget
NIBLIT_CHAT_MAX_CONTEXT_CHARS=8000

# Optional Ruflo HTTP bridge
RUFLO_API_URL=
RUFLO_API_KEY=
RUFLO_MODEL=
RUFLO_TIMEOUT=60
RUFLO_API_FORMAT=openai
RUFLO_CHAT_PATH=/v1/chat/completions

# Tunnel defaults — WSL can use cloudflared for remote bridge
NIBLIT_TUNNEL_TOOL=none
FLY_APP_NAME=niblit

# Runtime modes (Phase Ω.7)
NIBLIT_RUNTIME_MODE=normal
NIBLIT_SURVIVAL_MODE=false
NIBLIT_ATTENTION_PRESSURE=0.0
NIBLIT_COHERENCE_SCORE=1.0
NIBLIT_CONSTITUTIONAL_GATE=true
