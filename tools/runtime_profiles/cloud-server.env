# tools/runtime_profiles/cloud-server.env
# ─────────────────────────────────────────────────────────────────────────────
# Runtime profile: cloud-server
# Use for niblit-cloud-server and containerised cloud deployments.
# ─────────────────────────────────────────────────────────────────────────────

# Application identity
NIBLIT_APP_NAME=niblit-cloud-server
NIBLIT_RUNTIME_PROFILE=cloud-server

# Socket / transport — cloud prefers TCP for container networking
NIBLIT_CTL_SOCKET=
NIBLIT_CTL_HOST=0.0.0.0
NIBLIT_CTL_PORT=7681

# Inference backend
NIBLIT_GGUF_BACKEND=http
NIBLIT_LLAMA_PORT=8080
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
NIBLIT_RUNTIME_CONTEXT_TARGET=16384
NIBLIT_GGUF_N_CTX=16384
NIBLIT_GGUF_N_THREADS=8
# Max tokens generated per response
NIBLIT_LOCAL_MAX_NEW=512

# 16K context cognitive budget
NIBLIT_BRAIN_CONTEXT_MAX_CHARS=6000
NIBLIT_KB_TEXT_MAX_CHARS=1500
NIBLIT_BRAIN_CHAT_HISTORY_LIMIT=20
NIBLIT_BRAIN_CHAT_HISTORY_CONTENT_CHARS=800
NIBLIT_CHAT_MAX_HISTORY=40
NIBLIT_CHAT_MAX_CONTEXT_CHARS=8000

# Model paths
NIBLIT_GGUF_MODEL_PATH=/data/model.gguf

# Optional Ruflo HTTP bridge
RUFLO_API_URL=
RUFLO_API_KEY=
RUFLO_MODEL=
RUFLO_TIMEOUT=60
RUFLO_API_FORMAT=openai
RUFLO_CHAT_PATH=/v1/chat/completions

# Tunnel defaults (cloud typically uses load balancer, not tunnel)
NIBLIT_TUNNEL_TOOL=none
FLY_APP_NAME=niblit-cloud-server

# Runtime modes (Phase Ω.7)
NIBLIT_RUNTIME_MODE=normal
NIBLIT_SURVIVAL_MODE=false
NIBLIT_ATTENTION_PRESSURE=0.0
NIBLIT_COHERENCE_SCORE=1.0
NIBLIT_CONSTITUTIONAL_GATE=true
