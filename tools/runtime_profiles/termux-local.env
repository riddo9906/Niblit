# tools/runtime_profiles/termux-local.env
# ─────────────────────────────────────────────────────────────────────────────
# Runtime profile: termux-local
# Use for Android / Termux local inference deployments.
# ─────────────────────────────────────────────────────────────────────────────

# Application identity
NIBLIT_APP_NAME=niblit
NIBLIT_RUNTIME_PROFILE=termux-local

# Socket / transport
NIBLIT_CTL_SOCKET=/tmp/niblit-ctl.sock
NIBLIT_CTL_HOST=
NIBLIT_CTL_PORT=

# Inference backend
NIBLIT_GGUF_BACKEND=subprocess
NIBLIT_LLAMA_PORT=8080
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
NIBLIT_GGUF_N_CTX=2048
NIBLIT_GGUF_N_THREADS=4

# Model paths — Termux default locations
NIBLIT_GGUF_MODEL_PATH=/data/data/com.termux/files/home/models/qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_LLAMA_BINARY=/data/data/com.termux/files/home/llama.cpp/build/bin/llama-server

# Tunnel defaults — Termux typically uses cloudflared for Fly.io bridge
NIBLIT_TUNNEL_TOOL=cloudflared
FLY_APP_NAME=niblit

# Runtime modes (Phase Ω.7) — conservative defaults for mobile
NIBLIT_RUNTIME_MODE=normal
NIBLIT_SURVIVAL_MODE=false
NIBLIT_ATTENTION_PRESSURE=0.0
NIBLIT_COHERENCE_SCORE=1.0
NIBLIT_CONSTITUTIONAL_GATE=true
