# tools/runtime_profiles/niblit.env
# ─────────────────────────────────────────────────────────────────────────────
# Runtime profile: niblit
# Use for the main Niblit deployment (Fly.io / cloud VM / server).
# ─────────────────────────────────────────────────────────────────────────────

# Application identity
NIBLIT_APP_NAME=niblit
NIBLIT_RUNTIME_PROFILE=niblit

# Socket / transport
NIBLIT_CTL_SOCKET=/tmp/niblit-ctl.sock
NIBLIT_CTL_HOST=
NIBLIT_CTL_PORT=

# Inference backend
NIBLIT_GGUF_BACKEND=http
NIBLIT_LLAMA_PORT=8080
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
NIBLIT_GGUF_N_CTX=4096
NIBLIT_GGUF_N_THREADS=4

# Model paths (Ubuntu/WSL desktop defaults)
NIBLIT_GGUF_MODEL_PATH=/home/riddo9906/models/qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_MODEL_QWEN=/home/riddo9906/models/qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_MODEL_LLAMA3=/home/riddo9906/models/Llama-3.2-1B-Instruct-Q4_K_M.gguf

# Optional Ruflo HTTP bridge
RUFLO_API_URL=
RUFLO_API_KEY=
RUFLO_MODEL=
RUFLO_TIMEOUT=60
RUFLO_API_FORMAT=openai
RUFLO_CHAT_PATH=/v1/chat/completions

# Tunnel defaults
NIBLIT_TUNNEL_TOOL=
FLY_APP_NAME=niblit

# Runtime modes (Phase Ω.7)
NIBLIT_RUNTIME_MODE=normal
NIBLIT_SURVIVAL_MODE=false
NIBLIT_ATTENTION_PRESSURE=0.0
NIBLIT_COHERENCE_SCORE=1.0
NIBLIT_CONSTITUTIONAL_GATE=true
