# tools/runtime_profiles/niblit.env
# ─────────────────────────────────────────────────────────────────────────────
# Runtime profile: niblit
# Use for the main Niblit deployment (Fly.io / cloud VM / server).
# ─────────────────────────────────────────────────────────────────────────────

# Application identity
NIBLIT_APP_NAME=niblit
NIBLIT_RUNTIME_PROFILE=niblit

# Socket / transport
NIBLIT_CTL_SOCKET=/tmp/niblit-ctl.sock
NIBLIT_CTL_HOST=
NIBLIT_CTL_PORT=

# Inference backend
NIBLIT_GGUF_BACKEND=http
NIBLIT_LLAMA_PORT=8080
NIBLIT_LLAMA_SERVER_URL=http://127.0.0.1:8080
NIBLIT_RUNTIME_CONTEXT_TARGET=16384
NIBLIT_GGUF_N_CTX=16384
NIBLIT_GGUF_N_THREADS=4
# Max tokens generated per response (increased for richer output at 16K ctx)
NIBLIT_LOCAL_MAX_NEW=512

# 16K context cognitive budget
# KB context injected per inference call (~1500 tokens)
NIBLIT_BRAIN_CONTEXT_MAX_CHARS=6000
# Max chars per KB snippet
NIBLIT_KB_TEXT_MAX_CHARS=1500
# Chat history turns injected into brain think()
NIBLIT_BRAIN_CHAT_HISTORY_LIMIT=20
# Max chars per injected history message
NIBLIT_BRAIN_CHAT_HISTORY_CONTENT_CHARS=800
# Chat-completions history depth
NIBLIT_CHAT_MAX_HISTORY=40
# Chat-completions knowledge context budget
NIBLIT_CHAT_MAX_CONTEXT_CHARS=8000

# Model paths (Ubuntu/WSL desktop defaults)
NIBLIT_GGUF_MODEL_PATH=C:\Users\Riyaad\llama_migration\models\qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_MODEL_QWEN=C:\Users\Riyaad\llama_migration\models\qwen2.5-0.5b-instruct-q4_k_m.gguf
NIBLIT_MODEL_LLAMA3=C:\Users\Riyaad\llama_migration\models\Llama-3.2-1B-Instruct-Q4_K_M.gguf

# Optional Ruflo HTTP bridge
RUFLO_API_URL=
RUFLO_API_KEY=
RUFLO_MODEL=
RUFLO_TIMEOUT=60
RUFLO_API_FORMAT=openai
RUFLO_CHAT_PATH=/v1/chat/completions

# Tunnel defaults
NIBLIT_TUNNEL_TOOL=
FLY_APP_NAME=niblit

# Runtime modes (Phase Ω.7)
NIBLIT_RUNTIME_MODE=normal
NIBLIT_SURVIVAL_MODE=false
NIBLIT_ATTENTION_PRESSURE=0.0
NIBLIT_COHERENCE_SCORE=1.0
NIBLIT_CONSTITUTIONAL_GATE=true
