#!/usr/bin/env python3
"""
NIBLIT BRAIN MODULE
Handles thinking, learning, HFBrain integration, and self modules
"""

import datetime

# ─────────── Local DB Integration (ADDED, NON-INTRUSIVE) ───────────
try:
    from modules.db import LocalDB
except ImportError as e:
    LocalDB = None
    print(f"[niblit_brain] LocalDB import failed: {e}")

# ─────────── HFBrain Integration ───────────
try:
    from modules.hf_brain import HFBrain
except ImportError:
    HFBrain = None
    print("[niblit_brain] HFBrain module missing, continuing without it.")

# ─────────── Self Modules Integration ───────────
try:
    from modules.self_researcher import SelfResearcher
except ImportError:
    SelfResearcher = None
    print("[niblit_brain] SelfResearcher module missing, self-research commands will be limited.")

try:
    from modules.self_healer import SelfHealer
except ImportError:
    SelfHealer = None
    print("[niblit_brain] SelfHealer module missing, self-heal commands will be limited.")


# ─────────── Memory DB Adapter (ADDED ONLY) ───────────
class _DBMemoryAdapter:
    """
    Adapter that augments an existing memory object with LocalDB-backed
    storage IF those methods are missing.

    Does NOT replace memory.
    Does NOT change behavior.
    Only fills gaps HFBrain may rely on.
    """

    def __init__(self, memory, db_path="niblit.db"):
        self._memory = memory
        self._db = LocalDB(db_path) if LocalDB else None

    def __getattr__(self, name):
        return getattr(self._memory, name)

    # ---- optional learning persistence ----
    def store_learning(self, entry):
        if hasattr(self._memory, "store_learning"):
            return self._memory.store_learning(entry)
        if self._db:
            self._db.add_entry("learning", entry)

    # ---- optional recall ----
    def recall(self, query, limit=5):
        if hasattr(self._memory, "recall"):
            return self._memory.recall(query)
        if not self._db:
            return []
        results = []
        for item in reversed(self._db.get_log()):
            val = str(item.get("value", ""))
            if query.lower() in val.lower():
                results.append(item)
            if len(results) >= limit:
                break
        return results

    # ---- optional preferences ----
    def get_preferences(self):
        if hasattr(self._memory, "get_preferences"):
            return self._memory.get_preferences()
        return {}

    def store_preferences(self, prefs):
        if hasattr(self._memory, "store_preferences"):
            return self._memory.store_preferences(prefs)


class NiblitBrain:
    def __init__(self, memory):
        self.memory = memory

        # ─── ADDITIVE: Wrap memory ONLY if LocalDB exists ───
        if LocalDB and memory is not None:
            try:
                self.memory = _DBMemoryAdapter(memory)
            except Exception as e:
                print(f"[niblit_brain] DB adapter attach failed: {e}")

        # Safely handle preferences even if memory doesn't implement them
        try:
            prefs = self.memory.get_preferences()
            if not prefs:
                prefs = {"tone": "neutral", "interaction_style": "casual"}
                if hasattr(self.memory, "store_preferences"):
                    self.memory.store_preferences(prefs)
        except AttributeError:
            prefs = {"tone": "neutral", "interaction_style": "casual"}
        self.preferences = prefs

        # Initialize HFBrain
        try:
            if HFBrain:
                self.hf_brain = HFBrain(self.memory)
                print("[niblit_brain] HFBrain loaded successfully")
            else:
                self.hf_brain = None
        except RuntimeError as e:
            print(f"[niblit_brain] HFBrain failed to initialize: {e}")
            self.hf_brain = None

        # Initialize Self Modules if available
        self.self_researcher = SelfResearcher(self.memory) if SelfResearcher else None
        self.self_healer = SelfHealer(self.memory) if SelfHealer else None

    # ─────────── Learning ───────────
    def learn(self, user_input):
        try:
            if hasattr(self.memory, "store_learning"):
                self.memory.store_learning({
                    "time": datetime.datetime.utcnow().isoformat(),
                    "input": user_input
                })
        except Exception as e:
            print(f"[niblit_brain] Learning failed: {e}")

    # ─────────── Thinking ───────────
    def think(self, user_input):
        self.learn(user_input)

        # Attempt to recall relevant memories if supported
        context = ""
        try:
            if hasattr(self.memory, "recall"):
                recalled = self.memory.recall(user_input)
                if recalled:
                    context = "Based on what I've learned before:\n"
                    for r in recalled:
                        if isinstance(r, dict):
                            context += f"- {r.get('input')}\n"
                        else:
                            context += f"- {r}\n"
                    context += "\n"
        except Exception:
            context = ""

        prompt = context + user_input

        # Use HFBrain if available
        if self.hf_brain:
            try:
                response = self.hf_brain.ask_single(prompt)
                if response:
                    return response.strip()
            except Exception as e:
                print(f"[niblit_brain] HFBrain ask failed: {e}")

        return f"[neutral] I hear you: '{user_input}'"

    # ─────────── Command Handling ───────────
    def handle_command(self, command: str):
        """
        Handle special self modules like 'self-research' or 'self-heal'.
        """
        cmd = command.strip().lower()

        if cmd.startswith("self-research"):
            topic = cmd.replace("self-research", "").strip()
            if self.self_researcher:
                return self.self_researcher.run(topic or "general")
            else:
                return "SelfResearcher module not available."

        elif cmd.startswith("self-heal"):
            if self.self_healer:
                return self.self_healer.run()
            else:
                return "SelfHealer module not available."

        else:
            # Fallback to standard thinking
            return self.think(command)


# ─────────── HF Query Shortcut ───────────
def hf_query(prompt: str, memory=None):
    if memory is None:
        try:
            from niblit_memory import MemoryManager
            memory = MemoryManager()
        except Exception:
            memory = None
    brain = NiblitBrain(memory)
    return brain.think(prompt)


if __name__ == "__main__":
    print("Niblit brain online")
