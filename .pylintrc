[MESSAGES CONTROL]
# Disable messages that are noisy for this codebase.
#
# E0401 import-error: All third-party/local imports are wrapped in try/except
#   blocks intentionally — pylint cannot resolve them without PYTHONPATH.
#
# W0718 broad-exception-caught: Intentional in safe_import/safe_call patterns.
#
# W1203 logging-fstring-interpolation: Codebase uses f-strings in logging
#   throughout for readability; lazy-% would reduce clarity here.
#
# C0415 import-outside-toplevel: Optional imports inside methods are intentional
#   for optional heavy dependencies (psutil, resource, etc.).
#
# R0903 too-few-public-methods: Several small data/config classes intentionally
#   have fewer than 2 public methods.
disable=import-error,broad-exception-caught,logging-fstring-interpolation,import-outside-toplevel,too-few-public-methods

[FORMAT]
# Maximum number of characters on a single line.
max-line-length=120

# Regexp for a line that is allowed to be longer than the limit.
# (long-line-note-regexp is not recognized by pylint 4.x — commented out)
#long-line-note-regexp=^\s*(# )?<?https?://\S+>?$

# Number of spaces of indent required inside a hanging or continued line.
indent-after-paren=4

# String used as indentation unit. This is usually "    " (4 spaces) or "\t" (1 tab).
indent-string='    '

# Expected format of line ending, especially useful when checking scripts as
# they are prone to have the wrong line ending convention. This represents the
# line ending type to be considered as expected. Empty means any is acceptable.
expected-line-ending-format=

# Python expression which should return a note less than 10 (10 is the highest
# note). You have access to the variables errors warning, refactor and
# convention which represent the number of messages in each category, as well as
# _statement which represents the total number of statements analyzed. This is
# used by the global evaluation report (RP0004).
evaluation=
    max(0, 0 if fatal else 10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10))

# Template used to display messages. This is a python new-style format string
# used to format the message information. See doc for all details.
#msg-template=

[LOGGING]
# Format of logging format string.
logging-format-style=old

# Logging modules which allow lazy formatting of logging messages
logging-modules=logging

[BASIC]
# Naming style matching correct argument names.
argument-naming-style=snake_case

# Regular expression matching correct argument names. Overrides argument-
# naming-style. If left empty, argument names will be checked with the set
# naming style.
#argument-rgx=

# Naming style matching correct attribute names.
attr-naming-style=snake_case

# Regular expression matching correct attribute names. Overrides attr-naming-
# style. If left empty, attribute names will be checked with the set naming
# style.
#attr-rgx=

# Bad variable names which should always be refused, separated by a comma.
bad-names=foo,bar,baz,toto,tutu,tata

# Bad variable names regexes, separated by a comma. By default no bad variable
# names are configured for attributes.
#bad-names-rgxs=

# Naming style matching correct class attribute names.
class-attribute-naming-style=any

# Regular expression matching correct class attribute names. Overrides class-
# attribute-naming-style. If left empty, attribute names will be checked with
# the set naming style.
#class-attribute-rgx=

# Naming style matching correct class names.
class-naming-style=PascalCase

# Regular expression matching correct class names. Overrides class-naming-
# style. If left empty, class names will be checked with the set naming style.
#class-rgx=

# Naming style matching correct constant names.
const-naming-style=UPPER_CASE

# Regular expression matching correct constant names. Overrides const-naming-
# style. If left empty, constant names will be checked with the set naming
# style.
#const-rgx=

# Minimum line length for functions/classes that require docstrings, shorter
# ones are exempt.
docstring-min-length=-1

# Naming style matching correct function names.
function-naming-style=snake_case

# Regular expression matching correct function names. Overrides function-
# naming-style. If left empty, function names will be checked with the set
# naming style.
#function-rgx=

# Good variable names which should always be accepted, separated by a comma.
good-names=i,j,k,ex,Run,_,x,y,z,e,f

# Inclusive language checker can be disabled with this flag
include-naming-hint=false

# Naming style matching correct inline variable names.
inlinevar-naming-style=any

# Regular expression matching correct inline variable names. Overrides
# inlinevar-naming-style. If left empty, variable names will be checked with
# the set naming style.
#inlinevar-rgx=

# Naming style matching correct method names.
method-naming-style=snake_case

# Regular expression matching correct method names. Overrides method-naming-
# style. If left empty, method names will be checked with the set naming style.
#method-rgx=

# Naming style matching correct module names.
module-naming-style=snake_case

# Regular expression matching correct module names. Overrides module-naming-
# style. If left empty, module names will be checked with the set naming style.
#module-rgx=

# Colon-delimited sets of names that determine each other's naming style when
# the name regexes allow several styles. This is mainly useful for
# parameters, especially for function parameters that mirror instance
# attributes.
name-group=

# Regular expression which should only match function or class names that do
# not require a docstring.
no-docstring-rgx=^_

# List of decorators that produce properties, such as abc.abstractproperty. Add
# to this list to register other decorators that produce valid properties.
# These decorators are taken in account only for invalid-name.
property-classes=abc.abstractproperty

# Naming style matching correct variable names.
variable-naming-style=snake_case

# Regular expression matching correct variable names. Overrides variable-
# naming-style. If left empty, variable names will be checked with the set
# naming style.
#variable-rgx=

[DESIGN]
# Maximum number of arguments for function / method.
# (max-arguments not recognized by pylint 4.x, use max-positional-arguments)
#max-arguments=10

# Maximum number of attributes for a class.
max-attributes=7

# Maximum number of boolean expressions in an if statement.
max-bool-expr=5

# Maximum number of branch for function / method body.
max-branches=12

# Maximum number of locals for function / method body.
max-locals=15

# Maximum number of parents for a class (see R0901).
max-parents=7

# Maximum number of public methods for a class (see R0904).
max-public-methods=20

# Maximum number of return / yield for function / method body.
max-returns=6

# Maximum number of statements in function / method body.
max-statements=50

# Minimum number of public methods for a class (see R0903).
min-public-methods=2

[CLASSES]
# List of method names used to declare an abstract method. The naming style of
# these function names should be in '^lower_' pattern.
defining-attr-methods=__init__,__new__,setUp,__post_init__

# List of member names, which should be excluded from the protected access
# warning.
exclude-protected=_OrderedDict

# List of valid names for the first argument in a class method.
valid-classmethod-first-arg=cls

# List of valid names for the first argument in a metaclass class method.
valid-metaclass-classmethod-first-arg=cls

[IMPORTS]
# Force import order to recognize a module as part of a local package.
allow-wildcard-with-all=false

# Analyse import fallback blocks. This can be used to support both Python 2 and
# 3 compatible code, which means that the block might have duplicated imports
# and relative imports ignored in favour of absolute ones.
analyse-fallback-blocks=false

# Deprecated modules which should not be used, separated by a comma.
deprecated-modules=optparse,tkinter.tix

# Force import order to recognize a module as part of the standard
# compatibility libraries.
known-standard-library=
  asyncio,
  threading,
  logging,
  json,
  os,
  sys,
  time,
  datetime,

# Force import order to recognize a module as part of a third party library.
known-third-party=

# Modules that should be considered safe to import even if their initializers
# have side effects, which is mainly to support a deprecation of the old
# optparse module.
# (known-dangerous-modules not recognized by pylint 4.x — commented out)
#known-dangerous-modules=optparse

# Force a consistent ordering within each section of imports.
# (import-order not recognized by pylint 4.x — commented out)
#import-order=natural

[EXCEPTIONS]
# Exceptions that will emit a warning when being caught. Defaults to
# "BaseException, Exception".
overgeneral-exceptions=builtins.BaseException,builtins.Exception

[TYPING]
# (max-line-length-suggestions not recognized by pylint 4.x — section kept for reference)
# max-line-length-suggestions:

[VARIABLES]
# List of additional names supposed to be defined in builtins. Remember that
# you should avoid to define new builtins when possible.
additional-builtins=

# List of names which should be considered shadowed by a parameter or local
# variable. Used by the shadowed-import-checker to only emit a message if an
# imported module (i.e. added to locals) has the same name as a shadowed global.
allowed-redefined-builtins=

# List of strings which can identify a callback function by name. A callback
# name must start or end with one of those strings.
callbacks=cb_,_cb

# A regular expression matching the name of dummy variables (i.e. expected to
# not be used).
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+?)|dummy|unused|^\*{1,2}

# Argument names that match this expression will be ignored. Default to name
# with leading underscore.
ignored-argument-names=_.*|^ignored_|^unused_

# Tells whether unused global variables should be treated as a violation.
allow-global-unused-variables=true

# List of tuples (name, predicate) where predicate is a function template for
# checking if a name matches the predicate. The predicate receives the inferred
# object and should return a boolean. If the predicate is not a function, its
# value is assumed.
# checks-deprecated-method-option allows runtime configuration (through
# callbacks).
# (allowed-redefined-builtins already set above — duplicate removed)

[MISCELLANEOUS]
# List of note tags to take in consideration, separated by a comma.
notes=FIXME,XXX,TODO

# Regular expression of note tags to take in consideration, separated by a
# comma.
#notes-rgx=

[TYPECHECK]
# The minimum Python version to target
py-version=3.10

# List of decorators that produce context managers, such as
# contextlib.contextmanager. Add to this list to register other decorators that
# produce valid context managers.
contextmanager-decorators=contextlib.contextmanager

# List of members which are set dynamically and missed by pylint inference
# system, and so shouldn't trigger false positives when accessed as undefined.
generated-members=REQUEST,acl_users,aq_parent

# Tells whether to warn about missing members when the owner of the attribute
# is inferred to be None.
# (ignore-none-returning-functions not recognized by pylint 4.x — commented out)
#ignore-none-returning-functions=

# Tells whether to warn about missing members when an owner of an attribute is
# inferred to be None.
ignore-mixin-members=yes

# Ignore errors from member accesses on types inferred to be Any.
# (ignore-on-opaque-types not recognized by pylint 4.x — commented out)
#ignore-on-opaque-types=yes

# List of class names to which Pylint should not warn about accessing
# undefined members.
ignored-classes=optparse.Values,thread._local,_thread._local,pathlib.Path

# List of module names for which member attributes should not be checked
# (useful for modules/projects where namespaces are manipulated during runtime
# and thus existing member attributes cannot be deduced by static analysis). It
# supports qualified module names, as well as Unix pattern matching.
ignored-modules=

# List of decorators that produce other decorators, such as
# deprecated_decorator2. Add to this list to register other decorators that
# produce valid decorators.
# (decorator-transforms not recognized by pylint 4.x — commented out)
#decorator-transforms=

[SPELLING]
# Limits count of emitted suggestions for spelling mistakes.
max-spelling-suggestions=4

# Tells whether to store unknown words to indicated private dictionary file for
# future comparisons, to avoid false positives when running pylint next time.
spelling-store-unknown-words=no

# A path to a file that contains the private dictionary; note that the path
# must be absolute since the dictionary is cached for performance reasons.
#spelling-private-dict-file=

[SIMILARITIES]
# Comments are removed from the similarity computation
ignore-comments=yes

# Docstrings are removed from the similarity computation
ignore-docstrings=yes

# Imports are removed from the similarity computation
ignore-imports=yes

# Ignore similarities between imports and other lines
ignore-signatures=no

# Minimum lines number d a similarity.
min-similarity-lines=4

[PARAMETERS]
# Number of seconds to wait before starting to send termination signal to child
# processes started by pylint on Windows. Set this to 0 to instantly kill child
# processes on Windows. New in version 2.10.
# (wait-for-child not recognized by pylint 4.x — commented out)
#wait-for-child=10

[PERFORMANCE]
# Maximum number of local variables for function / method body.
# (max-local-variables not recognized by pylint 4.x — use max-locals in DESIGN)
# max-local-variables=15

# Maximum number of lines in a file.
max-module-lines=2000
