#!/usr/bin/env python3
"""
Unified NIBLIT_SYSTEM runtime (fully integrated option 2).
Replaces previous niblit_core.py with one unified runtime that:
- Loads modules from modules/ and tools/
- Instantiates managers (Filesystem, Internet, Memory, Server) into one runtime
- Provides robust constructor detection and fallbacks
- Provides CLI-friendly public methods for main.py to call
"""
import importlib
import inspect
import logging
import os
import sys
import traceback
from typing import Any, Dict, Optional

# ensure repo root is on path
REPO_ROOT = os.path.abspath(os.path.dirname(__file__))
if REPO_ROOT not in sys.path:
    sys.path.insert(0, REPO_ROOT)

# logging
log = logging.getLogger("niblit_core")
if not logging.getLogger().handlers:
    import logging as _lg
    _lg.basicConfig(level=_lg.INFO)
log.setLevel(logging.INFO)

# try load dotenv
try:
    from dotenv import load_dotenv
    load_dotenv()
except Exception:
    pass

HF_TOKEN = os.environ.get("HF_TOKEN", "") or os.environ.get("HUGGINGFACE_TOKEN", "")

# --- Helper utilities ---
def safe_import(module_name: str):
    try:
        mod = importlib.import_module(module_name)
        log.info(f"Loaded {module_name}")
        return mod
    except Exception as e:
        log.warning(f"Module {module_name} not found: {e}")
        return None

def try_instantiate(factory, db=None, modules=None):
    """
    Try to instantiate class or call factory with a set of sensible args.
    """
    if factory is None:
        return None
    try:
        sig = inspect.signature(factory)
        params = sig.parameters
        kwargs = {}
        # supply db and modules if requested by name
        if "db" in params and db is not None:
            kwargs["db"] = db
        if "memory" in params and db is not None:
            kwargs["memory"] = db
        if "modules" in params and modules is not None:
            kwargs["modules"] = modules
        if "runtime" in params:
            kwargs["runtime"] = None
        if kwargs:
            return factory(**kwargs)
    except Exception:
        # fallback: try no-arg constructor
        try:
            return factory()
        except Exception as e:
            log.debug(f"Instantiation failed for {factory}: {e}")
            return None
    # last-resort try no-arg
    try:
        return factory()
    except Exception as e:
        log.debug(f"Instantiation failed for {factory} (last resort): {e}")
        return None

# --- Stubs & Safe wrappers ---
class Stub:
    def __init__(self, name="stub"):
        self.name = name
        self.enabled = False
    def __getattr__(self, item):
        def _stub(*a, **k):
            log.debug(f"[Stub:{self.name}] called {item}")
            return f"[Stub:{self.name}] {item} not implemented"
        return _stub

# --- Simple Local DB used by many modules (lightweight, compatible) ---
class LocalDB:
    def __init__(self, path=None):
        self.path = path or os.path.join(REPO_ROOT, "niblit.db")
        self.data = {"interactions": [], "facts": []}
        try:
            if os.path.exists(self.path):
                import json
                self.data = json.loads(open(self.path, "r", encoding="utf-8").read() or "{}")
        except Exception:
            self.data = {"interactions": [], "facts": []}
            self._save()
    def _save(self):
        try:
            import json
            with open(self.path, "w", encoding="utf-8") as f:
                json.dump(self.data, f, indent=2)
        except Exception:
            pass
    def add_entry(self, key, value):
        import time
        self.data.setdefault("interactions", [])
        self.data["interactions"].append({"ts": time.time(), "key": key, "value": value})
        self._save()
    def get_log(self):
        return self.data.get("interactions", [])
    def list_facts(self, limit=500):
        return self.data.get("facts", [])[:limit]
    def add_fact(self, key, value, tags=None):
        tags = tags or []
        self.data.setdefault("facts", [])
        self.data["facts"].append({"key": key, "value": value, "tags": tags})
        self._save()
    def condense(self, keep_top=50):
        interactions = self.data.get("interactions", [])
        if len(interactions) > keep_top:
            self.data["interactions"] = interactions[-keep_top:]
            self._save()

# --- Unified runtime: NIBLIT_SYSTEM ---
class NiblitSystem:
    def __init__(self, memory_path: Optional[str] = None):
        # DB
        self.db = LocalDB(path=memory_path) if isinstance(memory_path, str) or memory_path is None else memory_path

        # module registry (name->instance or module)
        self.modules: Dict[str, Any] = {}

        # attempt to load core helpers first (tools/structural_helper, tools.repo_audit)
        self.tools = {}
        self._load_tools()

        # load modules from /modules
        self._load_standard_modules()

        # integrate managers into unified runtime
        self._integrate_managers()

        # runtime flags
        self.running = True
        self.llm_enabled = True
        # give db access to runtime registry (some modules expect this)
        try:
            setattr(self.db, "runtime_registry", self.modules)
        except Exception:
            pass

    # ---- Loading helpers ----
    def _load_tools(self):
        # prefer tools.<name>, but allow top-level imports to be present too
        names = ["tools.structural_helper", "tools.repo_audit", "tools.FixGuideGenerator", "tools.self_heal_auto"]
        for n in names:
            m = safe_import(n)
            if m:
                self.tools[n.split(".")[-1]] = m

    def _load_standard_modules(self):
        # attempt to import a set of known modules gracefully; also scan modules/ folder for .py files
        known = [
            "analytics","antifraud","bios","bootloader","control_panel","counter_active_membrane",
            "dashboard","device_manager","filesystem_manager","firmware","idea_generator",
            "permission_manager","reflect","self_healer","self_teacher","self_idea_implementation",
            "self_maintenance","slsa_generator","market_researcher","internet_manager","llm_adapter","llm_module",
            "local_llm_adapter","storage","terminal_tools","niblit_memory"
        ]
        for name in known:
            full = f"modules.{name}"
            mod = safe_import(full)
            if not mod:
                # try top-level fallback
                mod = safe_import(name)
            if mod is None:
                continue
            # if module exposes a primary class with same pattern, instantiate
            cls_name = "".join(p.capitalize() for p in name.split("_"))
            factory = getattr(mod, cls_name, None)
            inst = None
            if factory:
                inst = try_instantiate(factory, db=self.db, modules=self.modules)
            # otherwise store module itself
            self.modules[name] = inst if inst is not None else mod

    def _integrate_managers(self):
        # Filesystem manager
        fsm = self.modules.get("filesystem_manager")
        if isinstance(fsm, type) or inspect.ismodule(fsm):
            # if module, try to get FileSystemManager class
            cls = None
            if inspect.ismodule(fsm):
                cls = getattr(fsm, "FileSystemManager", None)
            else:
                cls = fsm
            inst = try_instantiate(cls, db=self.db, modules=self.modules)
            if inst:
                self.modules["filesystem"] = inst
        # Internet manager (wrap)
        im = self.modules.get("internet_manager")
        if inspect.ismodule(im):
            cls = getattr(im, "InternetManager", None)
            inst = try_instantiate(cls, db=self.db, modules=self.modules)
            if inst:
                self.modules["internet_manager"] = inst
        # memory (niblit_memory)
        mem = self.modules.get("niblit_memory")
        if inspect.ismodule(mem):
            cls = getattr(mem, "NiblitMemory", None) or getattr(mem, "Memory", None)
            inst = try_instantiate(cls, db=self.db, modules=self.modules)
            if inst:
                self.modules["niblit_memory"] = inst
        # attempt to instantiate repo_audit tool if available as class
        repo_audit_mod = self.tools.get("repo_audit") or safe_import("tools.repo_audit")
        if repo_audit_mod:
            self.tools["repo_audit"] = repo_audit_mod

    # ---- Runtime actions ----
    def boot(self):
        out = []
        try:
            bios = self.modules.get("bios")
            if bios and hasattr(bios, "boot_sequence"):
                out.append(bios.boot_sequence())
            else:
                out.append("BIOS: (none)")
        except Exception:
            out.append("BIOS: error")
        # boot other pieces if present
        try:
            boot = self.modules.get("bootloader")
            if boot and hasattr(boot, "start"):
                out.append(boot.start())
        except Exception:
            pass
        try:
            fw = self.modules.get("firmware")
            if fw and hasattr(fw, "load"):
                out.append(fw.load())
        except Exception:
            pass
        return "\n".join(out)

    def dashboard(self):
        # try to use dashboard.terminal_dashboard
        try:
            dash_mod = safe_import("modules.dashboard")
            if dash_mod and hasattr(dash_mod, "terminal_dashboard"):
                return dash_mod.terminal_dashboard(self.db, self.modules)
        except Exception as e:
            return f"[dashboard error] {e}"
        # fallback simple
        return f"Facts: {len(self.db.list_facts())}, Interactions: {len(self.db.get_log())}"

    def interact(self, text: str) -> str:
        try:
            af = self.modules.get("antifraud")
            antifraud_result = af.check(text) if af and hasattr(af, "check") else "No antifraud module."
            analytics = self.modules.get("analytics")
            analysis = analytics.analyze_text(text) if analytics and hasattr(analytics, "analyze_text") else ""
            idea_mod = self.modules.get("idea_generator")
            idea_snippet = idea_mod.generate(text) if idea_mod and hasattr(idea_mod, "generate") else ""
            reply = f"[AntiFraud] {antifraud_result}\n[Analysis] {analysis}\n[Ideas]\n{idea_snippet}"
            return reply
        except Exception as e:
            return f"[Interact Error] {e}"

    def query_llm(self, prompt: str, max_tokens: int = 120, prefer_local: bool = False) -> str:
        if not self.llm_enabled:
            return "[LLM] Disabled"
        # local adapter
        local = self.modules.get("local_llm_adapter")
        if local and hasattr(local, "query"):
            try:
                return local.query(prompt, max_tokens=max_tokens)
            except Exception:
                pass
        # external HF adapter
        hf = None
        # try module in tools or modules
        hf_mod = self.modules.get("llm_module") or safe_import("modules.llm_module")
        if hf_mod and hasattr(hf_mod, "query"):
            try:
                return hf_mod.query(prompt, max_tokens=max_tokens)
            except Exception:
                pass
        # last resort, pretend
        return "[LLM] No adapter available."

    def reload_module(self, module_name: str) -> str:
        # normalize
        if module_name.endswith(".py"):
            module_name = module_name[:-3]
        if module_name.startswith("modules."):
            module_name = module_name.split(".", 1)[1]
        try:
            mod = importlib.import_module(f"modules.{module_name}")
            importlib.reload(mod)
            cls_name = "".join(part.capitalize() for part in module_name.split("_"))
            factory = getattr(mod, cls_name, None)
            if factory:
                inst = try_instantiate(factory, db=self.db, modules=self.modules)
                if inst:
                    self.modules[module_name] = inst
                    return f"Reloaded and instantiated {module_name}"
            self.modules[module_name] = mod
            return f"Reloaded module code for {module_name}"
        except Exception as e:
            return f"Error reloading {module_name}: {e}\n{traceback.format_exc()}"

    # command handler (simpler interface)
    def handle(self, text: str) -> str:
        if not text:
            return "..."
        parts = text.strip().split()
        cmd = parts[0].lower()
        arg = " ".join(parts[1:]).strip()
        if cmd in ("help", "?"):
            return self._help_text()
        if cmd in ("boot", "start"):
            return self.boot()
        if cmd in ("status", "dashboard"):
            return self.dashboard()
        if cmd == "reload":
            if not arg:
                return "[reload] usage: reload <module>"
            return self.reload_module(arg)
        if cmd in ("query-llm", "query_llm"):
            return self.query_llm(arg)
        if cmd == "toggle":
            if not arg:
                return "[toggle] usage: toggle <module|llm> on|off"
            parts = arg.split()
            name = parts[0].lower()
            state = parts[1].lower() if len(parts) > 1 else None
            if name in ("llm", "hf"):
                self.llm_enabled = True if state == "on" else False if state == "off" else not self.llm_enabled
                return f"[toggle] LLM {'enabled' if self.llm_enabled else 'disabled'}"
            mod = self.modules.get(name)
            if mod and hasattr(mod, "enabled"):
                mod.enabled = True if state == "on" else False if state == "off" else not getattr(mod, "enabled", True)
                return f"[toggle] {name} is now {'enabled' if mod.enabled else 'disabled'}"
            return f"[toggle] unknown module: {name}"
        if cmd == "heal":
            mod = self.modules.get("self_healer")
            if mod and hasattr(mod, "repair"):
                try:
                    return mod.repair()
                except Exception as e:
                    return f"[heal error] {e}"
            return "[heal] self_healer missing."
        if cmd == "maintain":
            mod = self.modules.get("self_maintenance")
            if mod and hasattr(mod, "run"):
                try:
                    days = int(arg) if arg.isdigit() else 30
                    return mod.run(retention_days=days)
                except Exception as e:
                    return f"[maintain error] {e}"
            return "[maintain] self_maintenance missing."
        if cmd in ("research", "search", "web"):
            sr = self.modules.get("self_researcher")
            if not sr:
                return "[research] self_researcher missing."
            try:
                if hasattr(sr, "handle_command"):
                    return sr.handle_command("web.run", arg)
                if hasattr(sr, "search"):
                    results = sr.search(arg)
                    return "[WEB RESULTS]\n\n" + "\n\n".join(results)
            except Exception as e:
                return f"[research error] {e}"
        # default: interact
        return self.interact(text)

    def _help_text(self):
        return """boot/start — Boot Niblit
status/dashboard — Show dashboard
reload <module> — Hot reload module
query-llm <prompt> — Query LLM
toggle <module|llm> on/off
idea <prompt>
impl / implement <text|n>
reflect
teach <n>
heal
maintain <days>
research/search/web <query>
net/internet <subcommand>
exit
"""

if __name__ == "__main__":
    # quick smoke test
    ns = NiblitSystem()
    print("Running niblit_core (NIBLIT_SYSTEM) - modules:", ", ".join(sorted(ns.modules.keys())))
